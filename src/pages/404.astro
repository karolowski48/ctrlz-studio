---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Strona nie istnieje · CtrlZ Studio">

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">Ctrl<em>Z</em> Studio</a>
    <div class="nav-links">
      <a href="/#uslugi">Usługi</a>
      <a href="/realizacje">Realizacje</a>
      <a href="/#o-nas">O nas</a>
      <a href="/#kontakt">Kontakt</a>
    </div>
    <div style="display:flex;align-items:center;gap:12px">
      <a href="/#kontakt" class="btn-primary nav-cta-desktop" style="font-size:12px;padding:9px 20px"><span>Zacznijmy →</span></a>
      <button class="ham-btn" id="ham-btn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="/#uslugi">Usługi</a>
  <a href="/realizacje">Realizacje</a>
  <a href="/#o-nas">O nas</a>
  <a href="/#kontakt">Kontakt</a>
  <a href="/#kontakt" class="btn-primary mob-cta"><span>Zacznijmy →</span></a>
  <div class="mob-contact-row">
    <a href="mailto:kontakt@ctrlzstudio.pl" class="mob-contact-icon" aria-label="Email">
      <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
    <a href="tel:+48000000000" class="mob-contact-icon" aria-label="Telefon">
      <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1.13h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.72a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.92 16l.08.92z"/></svg>
    </a>
  </div>
</div>

<div class="page-404">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb" style="width:300px;height:300px;background:radial-gradient(circle,rgba(236,72,153,.15) 0%,transparent 70%);bottom:10%;right:10%;filter:blur(60px)"></div>
  <div class="grid-bg"></div>

  <div class="page-404-inner">
    <div class="glitch-num" id="num404">404</div>
    <div class="page-404-title" id="t404">Ups! Zgubiłeś się.</div>
    <p class="page-404-sub" id="s404">
      Ta strona nie istnieje — ale nasze realizacje jak najbardziej.<br>
      Wróć na stronę główną lub sprawdź portfolio.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap" id="btns404">
      <a href="/" class="btn-primary"><span>← Strona główna</span></a>
      <a href="/realizacje" class="btn-ghost">Zobacz realizacje</a>
    </div>
    <div style="margin-top:52px;display:flex;gap:32px;justify-content:center;flex-wrap:wrap;opacity:.5" id="links404">
      <a href="/#uslugi" style="font-size:13px;color:rgba(255,255,255,.6)">Usługi</a>
      <a href="/#o-nas"  style="font-size:13px;color:rgba(255,255,255,.6)">O nas</a>
      <a href="/#faq"    style="font-size:13px;color:rgba(255,255,255,.6)">FAQ</a>
      <a href="/#kontakt" style="font-size:13px;color:rgba(255,255,255,.6)">Kontakt</a>
    </div>
  </div>
</div>

</Layout>

<script>
import gsap from 'gsap';

const cursor=document.getElementById('cursor')!;
const ring=document.getElementById('cursor-ring')!;
let mx=0,my=0,rx=0,ry=0;
window.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;gsap.set(cursor,{x:mx,y:my});});
gsap.ticker.add(()=>{rx+=(mx-rx)*.12;ry+=(my-ry)*.12;gsap.set(ring,{x:rx,y:ry});});
window.addEventListener('scroll',()=>document.getElementById('nav')!.classList.toggle('scrolled',window.scrollY>60),{passive:true});

// Hamburger
const hamBtn=document.getElementById('ham-btn')!;
const mobMenu=document.getElementById('mobile-menu')!;
hamBtn.addEventListener('click',()=>{
  const open=hamBtn.classList.toggle('open');
  mobMenu.classList.toggle('open',open);
  document.body.style.overflow=open?'hidden':'';
});
mobMenu.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{
  hamBtn.classList.remove('open'); mobMenu.classList.remove('open'); document.body.style.overflow='';
}));

// 404 entrance
const tl=gsap.timeline({defaults:{ease:'power3.out'}});
tl.fromTo('#num404',{opacity:0,scale:.7,y:40},{opacity:1,scale:1,y:0,duration:1.1})
  .fromTo('#t404',  {opacity:0,y:20},{opacity:1,y:0,duration:.7},'-=.5')
  .fromTo('#s404',  {opacity:0,y:16},{opacity:1,y:0,duration:.6},'-=.4')
  .fromTo('#btns404',{opacity:0,y:12},{opacity:1,y:0,duration:.5},'-=.3')
  .fromTo('#links404',{opacity:0},{opacity:.5,duration:.4},'-=.2');

// Glitch
const g=document.getElementById('num404')!;
setInterval(()=>{
  gsap.to(g,{x:gsap.utils.random(-4,4),duration:.08,repeat:3,yoyo:true,ease:'none',
    onComplete:()=>gsap.set(g,{x:0})});
},3500);
</script>
