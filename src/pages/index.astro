---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- NAV -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="#home" class="nav-logo">Ctrl<em>Z</em> Studio</a>
    <div class="nav-links">
      <a href="#realizacje">Realizacje</a>
      <a href="#uslugi">Usługi</a>
      <a href="#proces">Proces</a>
      <a href="/o-nas">O nas</a>
      <a href="#faq">FAQ</a>
      <a href="/blog">Blog</a>
      <a href="#kontakt">Kontakt</a>
    </div>
    <div style="display:flex;align-items:center;gap:12px">
      <a href="/kalkulator" class="btn-ghost nav-cta-desktop" style="font-size:12px;padding:9px 18px">Wycena</a>
      <a href="#kontakt" class="btn-primary nav-cta-desktop" style="font-size:12px;padding:9px 20px"><span>Zacznijmy →</span></a>
      <button class="ham-btn" id="ham-btn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobile-menu">
  <button class="ham-close" id="ham-close" aria-label="Zamknij menu">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <a href="#realizacje">Realizacje</a>
  <a href="#uslugi">Usługi</a>
  <a href="#proces">Proces</a>
  <a href="/o-nas">O nas</a>
  <a href="#faq">FAQ</a>
  <a href="/blog">Blog</a>
  <a href="#kontakt">Kontakt</a>
  <div style="display:flex;flex-direction:column;gap:10px;margin-top:18px;width:80%;max-width:280px">
    <a href="/kalkulator" class="btn-ghost" style="font-size:14px;padding:13px 22px;border-radius:var(--radius-pill);text-align:center;width:100%;box-sizing:border-box;display:flex;align-items:center;justify-content:center">Wycena</a>
    <a href="#kontakt" class="btn-primary" style="font-size:14px;padding:13px 22px;border-radius:var(--radius-pill);text-align:center;width:100%;box-sizing:border-box;justify-content:center"><span>Zacznijmy →</span></a>
  </div>
  <div class="mob-contact-row">
    <a href="mailto:kontakt@ctrlzstudio.pl" class="mob-contact-icon" aria-label="Email">
      <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
    <a href="tel:+48723971451" class="mob-contact-icon" aria-label="Telefon">
      <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1.13h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.72a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.92 16l.08.92z"/></svg>
    </a>
  </div>
</div>

<main id="main-content">
<!-- HERO -->
<section class="hero" id="home">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="grid-bg"></div>

  <!-- Floating ambient shapes -->
  <div class="hero-shape hero-shape-1"></div>
  <div class="hero-shape hero-shape-2"></div>
  <div class="hero-shape hero-shape-3"></div>

  <!-- Drifting particles (generated by JS) -->
  <div id="hero-particles"></div>

  <div class="hero-inner">
    <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:18px" id="h-ey">
      <div class="hero-eyebrow" style="margin:0">Agencja kreatywna & digital — Polska</div>
      <div class="footer-badge" style="position:static;margin:0;font-size:11px;padding:5px 12px"><div class="badge-dot"></div>Przyjmujemy nowe projekty</div>
    </div>
    <h1 class="display-xl hero-title" id="h-title">
      Budujemy marki,<br>
      które <span class="grad-anim">naprawdę</span><br>
      <span class="italic-light">zarabiają</span><br>
      na siebie.
    </h1>
    <div class="hero-bottom" id="h-bot">
      <p class="hero-desc">
        Projektujemy i wdrażamy strony oraz sklepy internetowe,
        dla firm którym zależy na <strong>jakości</strong>.<br>
      </p>
      <div class="hero-cta">
        <a href="#kontakt" class="btn-primary"><span>Porozmawiaj o projekcie</span></a>
        <span class="hero-cta-sub">lub napisz: kontakt@ctrlzstudio.pl</span>
      </div>
    </div>
  </div>
  <div class="hero-scroll"><div class="hero-scroll-dot"></div><div class="hero-scroll-txt">Zjedź niżej</div></div>
</section>

<!-- MARQUEE -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <div class="marquee-item"><b>✦</b>Web Development</div>
    <div class="marquee-item"><b>✦</b>UI/UX Design</div>
    <div class="marquee-item"><b>✦</b>SEO & Performance</div>
    <div class="marquee-item"><b>✦</b>WordPress & WooCommerce</div>
    <div class="marquee-item"><b>✦</b>Branding Wizualny</div>
    <div class="marquee-item"><b>✦</b>Custom Solutions</div>
    <div class="marquee-item"><b>✦</b>Animacje & Motion</div>
    <div class="marquee-item"><b>✦</b>Web Development</div>
    <div class="marquee-item"><b>✦</b>UI/UX Design</div>
    <div class="marquee-item"><b>✦</b>SEO & Performance</div>
    <div class="marquee-item"><b>✦</b>WordPress & WooCommerce</div>
    <div class="marquee-item"><b>✦</b>Branding Wizualny</div>
    <div class="marquee-item"><b>✦</b>Custom Solutions</div>
    <div class="marquee-item"><b>✦</b>Animacje & Motion</div>
  </div>
</div>

<!-- STATEMENT -->
<section class="section" style="background:var(--bg-base)">
  <div class="container" style="position:relative">
    <div class="statement-inner">
      <div class="eyebrow js-reveal" style="margin-bottom:14px">Dlaczego CtrlZ</div>
      <div class="statement-text js-reveal">
        Większość agencji robi <span class="dim">szablony.</span><br>
        My robimy <span class="grad-v">narzędzia sprzedaży</span><br>
        <span class="dim">w formie stron internetowych.</span>
      </div>
      <p class="statement-sub js-reveal">Każdy projekt zaczyna się od zrozumienia Twojego biznesu, konkurencji i celów. Dopiero potem projektujemy. Dlatego nasze strony konwertują.</p>
      <div class="numbers-row">
        <div class="num-item js-reveal">
          <div class="num js-count" data-to="7" data-suffix="+">7+</div>
          <div class="num-label">lat doświadczenia</div>
        </div>
        <div class="num-item js-reveal" data-delay="0.1">
          <div class="num js-count" data-to="250" data-suffix="+">250+</div>
          <div class="num-label">wdrożonych projektów</div>
        </div>
        <div class="num-item js-reveal" data-delay="0.2">
          <div class="num js-count" data-to="99" data-suffix="%">99%</div>
          <div class="num-label">zadowolonych klientów</div>
        </div>
      </div>
    </div>
    <div class="statement-metrics">
      <div class="metric-card js-reveal-r"><div class="metric-label">Śr. wzrost konwersji</div><div class="metric-val">+143%</div><div class="metric-sub">po redesignie z CtrlZ</div><div class="metric-bar"><div class="metric-fill" style="width:100%"></div></div></div>
      <div class="metric-card js-reveal-r" data-delay="0.1"><div class="metric-label">Czas ładowania</div><div class="metric-val">&lt;0.8s</div><div class="metric-sub">średni LCP naszych stron</div><div class="metric-bar"><div class="metric-fill" style="width:88%"></div></div></div>
      <div class="metric-card js-reveal-r" data-delay="0.2"><div class="metric-label">Klienci wracają</div><div class="metric-val">37%</div><div class="metric-sub">zleca kolejne projekty</div><div class="metric-bar"><div class="metric-fill" style="width:67%"></div></div></div>
    </div>
  </div>
</section>

<!-- PORTFOLIO -->
<section class="section" id="realizacje" style="background:var(--bg-base);padding-top:0">
  <div class="container">
    <div class="work-header">
      <h2 class="display-md js-reveal">Sprawdź wybrane<br><span class="grad-v">realizacje</span></h2>
      <a href="/realizacje" class="work-all-link js-reveal">Zobacz wszystkie →</a>
    </div>
    <div class="portfolio-featured">
      <a href="/realizacje/modeka" class="port-card tall pbg-7 js-scale"><img src="/modeka-hero.jpg" alt="Modeka" class="port-bg-img"/><div class="port-info"><div class="port-tag">E-commerce B2B · WooCommerce · 2026</div><div class="port-name">Modeka — B2B e-commerce</div><div class="port-pills"><span class="port-pill accent">4 kraje</span><span class="port-pill">1000+ produktów</span></div></div></a>
      <a href="/realizacje/eduinspirations" class="port-card tall pbg-9 js-scale" data-delay="0.1"><img src="/eduinspirations-hero.jpg" alt="EduInspirations" class="port-bg-img"/><div class="port-info"><div class="port-tag">E-commerce · Redesign · 2026</div><div class="port-name">EduInspirations.pl</div><div class="port-pills"><span class="port-pill accent">PageSpeed 90+</span><span class="port-pill">Custom Plugins</span></div></div></a>
    </div>
    <div class="portfolio-row">
      <a href="/realizacje/techopiekun" class="port-card short pbg-8 js-scale"><img src="/techopiekun-hero.jpg" alt="TechOpiekun" class="port-bg-img" loading="lazy"/><div class="port-info"><div class="port-tag">Strona firmowa · WordPress · 2026</div><div class="port-name">TechOpiekun.pl</div><div class="port-pills"><span class="port-pill accent">Serwis + SEO</span></div></div></a>
      <a href="/realizacje/ayra-jubiler" class="port-card short pbg-10 js-scale" data-delay="0.1"><img src="/ayra-hero.jpg" alt="Ayra Jubiler" class="port-bg-img" loading="lazy"/><div class="port-info"><div class="port-tag">E-commerce · WooCommerce · 2026</div><div class="port-name">Ayra Jubiler</div><div class="port-pills"><span class="port-pill accent">Automatyzacja</span></div></div></a>
      <a href="/realizacje/old-gold-garage" class="port-card short pbg-12 js-scale" data-delay="0.2"><img src="/oldgoldgarage.jpg" alt="Old Gold Garage" class="port-bg-img" loading="lazy"/><div class="port-info"><div class="port-tag">One Page · WordPress · 2026</div><div class="port-name">Old Gold Garage</div><div class="port-pills"><span class="port-pill accent">Dźwięk silnika</span></div></div></a>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" id="uslugi" style="background:var(--bg-surface)">
  <div class="container">
    <div class="eyebrow js-reveal" style="margin-bottom:14px">Co robimy</div>
    <h2 class="display-md js-reveal" style="margin-bottom:10px">Kompleksowe usługi<br><span class="grad-v">dla Twojej marki</span></h2>
    <p class="js-reveal" style="font-size:14px;color:rgba(255,255,255,.65);margin-bottom:48px;font-weight:300">Od projektu graficznego przez wdrożenie, aż po optymalizację i opiekę</p>
    <div class="services-grid">
      <div class="service-card js-scale"><div class="service-num">01</div><div class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div><div class="service-title">Web Development</div><div class="service-desc">Strony firmowe pisane w Next.js, sklepy internetowe, dedykowane motywy WordPress. Szybkie, responsywne, bez kompromisów.</div><div class="service-tags"><span class="service-tag">WordPress</span><span class="service-tag">WooCommerce</span><span class="service-tag">IdoSell</span><span class="service-tag">Next.js</span><span class="service-tag">Astro.js</span></div><div class="service-arrow">→</div></div>
      <div class="service-card js-scale" data-delay="0.07"><div class="service-num">02</div><div class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg></div><div class="service-title">UI/UX Design</div><div class="service-desc">Interfejsy, które konwertują. Od prototypu po gotowy produkt — z troską o każdy piksel.</div><div class="service-tags"><span class="service-tag">Figma</span><span class="service-tag">Prototypy</span><span class="service-tag">Animacje</span></div><div class="service-arrow">→</div></div>
      <div class="service-card js-scale" data-delay="0.14"><div class="service-num">03</div><div class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div><div class="service-title">SEO & Optymalizacja</div><div class="service-desc">Audyty, optymalizacja techniczna, poprawa Core Web Vitals. Widoczność w Google.</div><div class="service-tags"><span class="service-tag">Audyt SEO</span><span class="service-tag">CWV</span><span class="service-tag">SXO</span></div><div class="service-arrow">→</div></div>
      <div class="service-card js-scale" data-delay="0.07"><div class="service-num">04</div><div class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div><div class="service-title">Custom Solutions</div><div class="service-desc">ACF, API, konfiguratory, aplikacje webowe. Masz problem? Znajdziemy dogodne rozwiązanie.</div><div class="service-tags"><span class="service-tag">ACF</span><span class="service-tag">REST API</span><span class="service-tag">Integracje</span></div><div class="service-arrow">→</div></div>
      <div class="service-card js-scale" data-delay="0.14"><div class="service-num">05</div><div class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div class="service-title">Wsparcie Techniczne</div><div class="service-desc">Aktualizacje, backup, monitoring, bezpieczeństwo. Stała opieka nad Twoją stroną.</div><div class="service-tags"><span class="service-tag">Backup</span><span class="service-tag">Monitoring</span><span class="service-tag">Certyfikat SSL</span></div><div class="service-arrow">→</div></div>
      <div class="service-card js-scale" data-delay="0.21"><div class="service-num">06</div><div class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div><div class="service-title">Audyty & Modernizacja</div><div class="service-desc">Twoja strona nie działa? Przeprowadzimy pełny audyt i naprawimy ją lub stworzymy całkowicie nowy projekt.</div><div class="service-tags"><span class="service-tag">Redesign</span><span class="service-tag">Performance</span><span class="service-tag">UI/UX Audyt</span></div><div class="service-arrow">→</div></div>
    </div>
  </div>
</section>

<!-- PROCESS — REDESIGNED AS CARD GRID, NO LINE ISSUE -->
<section class="section" id="proces" style="background:var(--bg-base)">
  <div class="container">
    <div class="process-layout">
      <div>
        <div class="eyebrow js-reveal" style="margin-bottom:14px">Jak pracujemy</div>
        <h2 class="display-md js-reveal" style="margin-bottom:20px">Prosty proces<br><span class="grad-v">Lepsze wyniki</span></h2>
        <p class="process-intro js-reveal">Nie lubimy niespodzianek — ani my, ani nasi klienci. Każdy etap jest przejrzysty, mierzalny i zatwierdzany przez Ciebie przed przejściem dalej.</p>
        <div class="process-highlight js-reveal">
          <div class="process-highlight-title">Bez ukrytych kosztów</div>
          <div class="process-highlight-desc">Indywidualna, szczegółowa wycena przed startem projektu - klient dostaje konkretną rozpiskę z cenami i etapami pracy </div>
        </div>
      </div>
      <div class="process-steps">
        <div class="process-step js-scale">
          <div class="step-num">01</div>
          <div class="step-body"><div class="step-title">Audyt</div><div class="step-desc">Poznajemy Twój biznes, cele i grupę docelową. Zakres, terminy i budżety.</div></div>
        </div>
        <div class="process-step js-scale" data-delay="0.06">
          <div class="step-num">02</div>
          <div class="step-body"><div class="step-title">Design & Prototypowanie</div><div class="step-desc">Klikalne makiety w Figmie przed napisaniem linii kodu. Pełna kontrola.</div></div>
        </div>
        <div class="process-step js-scale" data-delay="0.12">
          <div class="step-num">03</div>
          <div class="step-body"><div class="step-title">Development</div><div class="step-desc">Kodujemy stronę, klient dostaje środowisko testowe.</div></div>
        </div>
        <div class="process-step js-scale" data-delay="0.06">
          <div class="step-num">04</div>
          <div class="step-body"><div class="step-title">Testy & Optymalizacja</div><div class="step-desc">Testy mobililnej wersji, poprawa wskaźników Core Web Vitals.</div></div>
        </div>
        <div class="process-step js-scale" data-delay="0.12">
          <div class="step-num">05</div>
          <div class="step-body"><div class="step-title">Deploy</div><div class="step-desc">Migrujemy projekt na domenę klienta, ustawienie certyfikatu SSL, podpięcie integracji. </div></div>
        </div>
        <div class="process-step js-scale" data-delay="0.18">
          <div class="step-num">06</div>
          <div class="step-body"><div class="step-title">Opieka Techniczna</div><div class="step-desc">Zostajemy z Tobą. Aktualizacje, monitoring, wsparcie. Skupiasz się na biznesie, my opiekujemy się twoją stroną.</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="section" id="o-nas" style="background:var(--bg-surface);position:relative">
  <div class="orb" style="width:400px;height:400px;background:radial-gradient(circle,rgba(236,72,153,.09) 0%,transparent 65%);bottom:-80px;right:-60px;filter:blur(70px)"></div>
  <div class="container">
    <div class="about-layout">
      <div>
        <div class="about-label">Za kulisami</div>
        <div class="about-quote js-reveal">"Jesteśmy agencją, która buduje<br><strong>marki od zera.</strong>"</div>
        <p class="about-body js-reveal">CtrlZ Studio to nowoczesna agencja developerska stworzona z pasji do <strong>designu</strong> i <strong>technologii</strong>. Łączymy estetykę projektowania z precyzją kodu, tworząc strony i sklepy internetowe, które nie tylko dobrze wyglądają, ale przede wszystkim skutecznie działają.</p>

        <p class="about-body js-reveal" style="margin-top:10px"><strong>Karol</strong> — Właściciel, grafik komputerowy i web developer z <strong>7-letnim doświadczeniem</strong>. Specjalizujemy się w rozwiązaniach opartych o <strong>WordPress</strong> oraz <strong>IdoSell CMS</strong>, stawiając na nowoczesny design, wydajność i dopracowane detale.</p>
        <div class="about-skills js-reveal">
          <span class="skill-pill">WordPress</span><span class="skill-pill">WooCommerce</span><span class="skill-pill">IdoSell</span><span class="skill-pill">Figma</span><span class="skill-pill">GSAP</span><span class="skill-pill">PHP</span><span class="skill-pill">SCSS</span><span class="skill-pill">ACF</span><span class="skill-pill">Next.js</span><span class="skill-pill">Astro.js</span>
        </div>
        <div class="about-cta js-reveal">
          <a href="/o-nas" class="btn-primary" style="font-size:13px;padding:12px 24px"><span>Czytaj więcej →</span></a>
          <a href="/realizacje" class="btn-ghost" style="font-size:13px;padding:12px 22px">Zobacz realizacje</a>
        </div>
        <div class="about-sig js-reveal" style="margin-top:28px">
          <div class="sig-avatar">K</div>
          <div><div class="sig-name">Karol</div><div class="sig-role">Founder & Lead Designer/Developer · CtrlZ Studio</div></div>
        </div>
      </div>
      <div class="about-stats js-reveal-r">
        <div class="stat-row"><div><div class="stat-label">Projekty WordPress</div><div class="stat-bar"><div class="stat-fill" style="width:80%"></div></div></div><div class="stat-val">80+</div></div>
        <div class="stat-row"><div><div class="stat-label">Sklepy WooCommerce</div><div class="stat-bar"><div class="stat-fill" style="width:58%"></div></div></div><div class="stat-val">60+</div></div>
        <div class="stat-row"><div><div class="stat-label">Projekty IdoSell</div><div class="stat-bar"><div class="stat-fill" style="width:30%"></div></div></div><div class="stat-val">30+</div></div>
        <div class="stat-row"><div><div class="stat-label">Projekty UI/UX (Figma)</div><div class="stat-bar"><div class="stat-fill" style="width:70%"></div></div></div><div class="stat-val">70+</div></div>
        <div class="stat-row"><div><div class="stat-label">Klienci długoterminowi</div><div class="stat-bar"><div class="stat-fill" style="width:37%"></div></div></div><div class="stat-val">37%</div></div>
        <div class="stat-row"><div><div class="stat-label">Lat doświadczenia</div><div class="stat-bar"><div class="stat-fill" style="width:100%"></div></div></div><div class="stat-val">7+</div></div>
      </div>
    </div>
  </div>
</section>

<!-- TECHNOLOGIES -->
<section class="section" style="background:var(--bg-surface)">
  <div class="container">
