<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// ── Performance: reduce ScrollTrigger reflow ──
ScrollTrigger.config({
  limitCallbacks: true,
  autoRefreshEvents: 'visibilitychange,DOMContentLoaded,load',
});
gsap.ticker.lagSmoothing(500, 33);

// ── Cursor — skip on touch devices ──────────────
const isTouchDevice = window.matchMedia('(hover: none), (pointer: coarse)').matches;
const cursor = document.getElementById('cursor')!;
const ring   = document.getElementById('cursor-ring')!;
let mx=0,my=0,rx=0,ry=0;
if (!isTouchDevice) {
  window.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;gsap.set(cursor,{x:mx,y:my});});
  gsap.ticker.add(()=>{rx+=(mx-rx)*.12;ry+=(my-ry)*.12;gsap.set(ring,{x:rx,y:ry});});
} else {
  cursor.style.display='none';
  ring.style.display='none';
}

// ── Nav active section highlight ─────────────────
const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-links a');
const sections = ['home','realizacje','uslugi','proces','o-nas','faq','kontakt','blog'];
const sectionEls = sections.map(id => document.getElementById(id)).filter(Boolean);

const navObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      navLinks.forEach(a => {
        const href = a.getAttribute('href') || '';
        const matches = href === `#${id}` || href === `/${id}` || (id === 'o-nas' && href === '/o-nas');
        a.classList.toggle('nav-active', matches);
      });
    }
  });
}, { rootMargin: '-20% 0px -75% 0px' });
sectionEls.forEach(el => el && navObserver.observe(el));

// ── Nav scroll ───────────────────────────────────
const nav=document.getElementById('nav')!;
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',window.scrollY>60),{passive:true});

// ── STT ──────────────────────────────────────────
const stt=document.getElementById('stt')!;
window.addEventListener('scroll',()=>stt.classList.toggle('visible',window.scrollY>300),{passive:true});
stt.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));

// ── Hamburger + X close ──────────────────────────
const hamBtn  = document.getElementById('ham-btn')!;
const hamClose= document.getElementById('ham-close')!;
const mobMenu = document.getElementById('mobile-menu')!;

function openMob(){
  hamBtn.classList.add('open');
  mobMenu.classList.add('open');
  document.body.style.overflow='hidden';
  gsap.fromTo('.mobile-menu a:not(.mob-contact-icon), .mobile-menu .btn-primary',
    {opacity:0,y:20},{opacity:1,y:0,duration:.4,ease:'power3.out',stagger:.06,delay:.05});
  gsap.fromTo('.mob-contact-row',
    {opacity:0,y:12},{opacity:1,y:0,duration:.4,ease:'power3.out',delay:.45});
}
function closeMob(){
  hamBtn.classList.remove('open');
  mobMenu.classList.remove('open');
  document.body.style.overflow='';
}
hamBtn.addEventListener('click', openMob);
hamClose.addEventListener('click', closeMob);
mobMenu.querySelectorAll('a').forEach(a=>a.addEventListener('click', closeMob));

// ── Hero entrance ─────────────────────────────────
gsap.fromTo('#h-ey',    {opacity:0,y:20},{opacity:1,y:0,duration:.9,ease:'power3.out',delay:.2});
gsap.fromTo('#h-title', {opacity:0,y:36},{opacity:1,y:0,duration:1.1,ease:'power3.out',delay:.38});
gsap.fromTo('#h-bot',   {opacity:0,y:24},{opacity:1,y:0,duration:1,  ease:'power3.out',delay:.6});

// ── Hero floating particles — stronger ───────────
const particleContainer = document.getElementById('hero-particles')!;
const colors = ['rgba(124,107,255,.85)','rgba(167,139,250,.75)','rgba(236,72,153,.75)','rgba(99,102,241,.8)','rgba(192,132,252,.7)'];

for(let i=0;i<22;i++){
  const p = document.createElement('div');
  p.className = 'hero-particle';
  const size = gsap.utils.random(4,10);
  const col  = colors[Math.floor(Math.random()*colors.length)];
  const dur  = gsap.utils.random(5,12);
  const del  = gsap.utils.random(0,10);
  const left = gsap.utils.random(5,95);
  const startY = gsap.utils.random(55,95);
  Object.assign(p.style,{
    width:`${size}px`, height:`${size}px`,
    background: col,
    left:`${left}%`, top:`${startY}%`,
    position:'absolute', borderRadius:'50%',
    filter:`blur(${size > 7 ? 1 : 0}px)`,
    boxShadow:`0 0 ${size*3}px ${col}, 0 0 ${size*6}px ${col.replace(/[\d.]+\)$/,'0.3)')}`,
    animation:`particleDrift ${dur}s ease-in-out infinite ${del}s`,
  });
  particleContainer.appendChild(p);
}

// ── Stat bars — fill then pulse ──────────────────
document.querySelectorAll<HTMLElement>('.stat-fill').forEach(bar => {
  const targetW = bar.style.width;
  bar.style.width = '0%';
  bar.style.transition = 'none';

  ScrollTrigger.create({
    trigger: bar,
    start: 'top 88%',
    once: true,
    onEnter: () => {
      // First: animate width from 0 to target
      gsap.to(bar, {
        width: targetW,
        duration: 1.4,
        ease: 'power3.out',
        delay: 0.1,
        onComplete: () => {
          // Then: start subtle pulse
          bar.classList.add('pulsing');
        }
      });
    }
  });
});

// ── Mouse parallax on hero orbs ───────────────────
const heroEl = document.querySelector('.hero')!;
heroEl.addEventListener('mousemove',(e:Event)=>{
  const me = e as MouseEvent;
  const rect = heroEl.getBoundingClientRect();
  const cx = (me.clientX - rect.left) / rect.width  - 0.5;
  const cy = (me.clientY - rect.top)  / rect.height - 0.5;
  gsap.to('.hero-shape-1',{x: cx*30, y: cy*20, duration:1.5, ease:'power2.out'});
  gsap.to('.hero-shape-2',{x:-cx*20, y:-cy*15, duration:1.5, ease:'power2.out'});
  gsap.to('.hero-shape-3',{x: cx*15, y: cy*25, duration:1.5, ease:'power2.out'});
  gsap.to('.orb-1',        {x: cx*18, y: cy*12, duration:2,   ease:'power2.out'});
  gsap.to('.orb-2',        {x:-cx*12, y:-cy*8,  duration:2,   ease:'power2.out'});
});

// ── Scroll reveals ───────────────────────────────
document.querySelectorAll<HTMLElement>('.js-reveal').forEach(el=>{
  const d=parseFloat(el.dataset.delay||'0');
  gsap.fromTo(el,{opacity:0,y:30},{opacity:1,y:0,duration:.8,ease:'power3.out',delay:d,
    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}});
});
document.querySelectorAll<HTMLElement>('.js-reveal-r').forEach(el=>{
  const d=parseFloat(el.dataset.delay||'0');
  gsap.fromTo(el,{opacity:0,x:32},{opacity:1,x:0,duration:.8,ease:'power3.out',delay:d,
    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}});
});
document.querySelectorAll<HTMLElement>('.js-scale').forEach(el=>{
  const d=parseFloat(el.dataset.delay||'0');
  gsap.fromTo(el,{opacity:0,scale:.93},{opacity:1,scale:1,duration:.85,ease:'power3.out',delay:d,
    scrollTrigger:{trigger:el,start:'top 90%',toggleActions:'play none none none'}});
});

// ── Counters ─────────────────────────────────────
document.querySelectorAll<HTMLElement>('.js-count').forEach(el=>{
  const to=parseInt(el.dataset.to||'0');
  const suffix=el.dataset.suffix||'';
  let done=false;
  ScrollTrigger.create({trigger:el,start:'top 85%',onEnter:()=>{
    if(done)return; done=true;
    const obj={val:0};
    gsap.to(obj,{val:to,duration:2,ease:'power2.out',onUpdate(){el.textContent=Math.round(obj.val)+suffix;}});
  }});
});

// ── Parallax orbs ────────────────────────────────
document.querySelectorAll<Element>('.orb').forEach((orb,i)=>{
  gsap.to(orb,{y:(i%2===0?-50:50),ease:'none',
    scrollTrigger:{trigger:'body',start:'top top',end:'bottom bottom',scrub:1.5+i*.4}});
});

// ── Tilt — service cards ─────────────────────────
document.querySelectorAll<HTMLElement>('.service-card').forEach(card=>{
  card.addEventListener('mousemove',(e:MouseEvent)=>{
    const r=card.getBoundingClientRect();
    gsap.to(card,{rotateX:-((e.clientY-r.top)/r.height-.5)*9,rotateY:((e.clientX-r.left)/r.width-.5)*9,
      duration:.4,ease:'power2.out',transformPerspective:800});
  });
  card.addEventListener('mouseleave',()=>gsap.to(card,{rotateX:0,rotateY:0,duration:.5,ease:'power3.out'}));
});

// ── Tilt — port cards ────────────────────────────
document.querySelectorAll<HTMLElement>('.port-card').forEach(card=>{
  card.addEventListener('mousemove',(e:MouseEvent)=>{
    const r=card.getBoundingClientRect();
    gsap.to(card,{rotateX:-((e.clientY-r.top)/r.height-.5)*10,rotateY:((e.clientX-r.left)/r.width-.5)*10,
      duration:.4,ease:'power2.out',transformPerspective:1000});
  });
  card.addEventListener('mouseleave',()=>gsap.to(card,{rotateX:0,rotateY:0,duration:.5,ease:'power3.out'}));
});

// ── Testimonials slider ──────────────────────────
(function(){
  const track   = document.getElementById('testi-track') as HTMLElement;
  const wrap    = document.getElementById('testi-slider-wrap') as HTMLElement;
  const dotsEl  = document.getElementById('testi-dots') as HTMLElement;
  const btnPrev = document.getElementById('testi-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('testi-next') as HTMLButtonElement;
  if (!track) return;

  const slides = Array.from(track.children) as HTMLElement[];
  let current  = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;

  // How many slides visible at once
  function perView() {
    const w = window.innerWidth;
    if (w < 600) return 1;
    if (w < 900) return 2;
    return 3;
  }

  function maxIndex() { return Math.max(0, slides.length - perView()); }

  function buildDots() {
    dotsEl.innerHTML = '';
    const count = maxIndex() + 1;
    for (let i = 0; i < count; i++) {
      const d = document.createElement('button');
      d.className = 'testi-dot' + (i === current ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsEl.appendChild(d);
    }
  }

  function updateDots() {
    dotsEl.querySelectorAll('.testi-dot').forEach((d, i) =>
      d.classList.toggle('active', i === current));
  }

  function getSlideWidth() {
    if (!slides[0]) return 0;
    return slides[0].getBoundingClientRect().width + 24;
  }

  function goTo(idx: number) {
    current = Math.max(0, Math.min(idx, maxIndex()));
    track.style.transform = `translateX(-${current * getSlideWidth()}px)`;
    updateDots();
  }

  function next() { goTo(current < maxIndex() ? current + 1 : 0); }
  function prev() { goTo(current > 0 ? current - 1 : maxIndex()); }

  function startAutoplay() {
    clearInterval(autoplayTimer);
    autoplayTimer = setInterval(next, 4500);
  }
  function pauseAutoplay() { clearInterval(autoplayTimer); }

  btnNext.addEventListener('click', () => { next(); startAutoplay(); });
  btnPrev.addEventListener('click', () => { prev(); startAutoplay(); });

  wrap.addEventListener('mouseenter', pauseAutoplay);
  wrap.addEventListener('mouseleave', startAutoplay);

  // Drag / swipe
  let dragStart = 0, dragging = false;
  track.addEventListener('mousedown',  e => { dragging=true; dragStart=e.clientX; pauseAutoplay(); });
  track.addEventListener('touchstart', e => { dragging=true; dragStart=e.touches[0].clientX; pauseAutoplay(); }, {passive:true});
  function onDragEnd(endX: number) {
    if (!dragging) return;
    dragging = false;
    const diff = dragStart - endX;
    if (Math.abs(diff) > 50) diff > 0 ? next() : prev();
    startAutoplay();
  }
  track.addEventListener('mouseup',   e => onDragEnd(e.clientX));
  track.addEventListener('mouseleave',e => { if(dragging) onDragEnd(e.clientX); });
  track.addEventListener('touchend',  e => onDragEnd(e.changedTouches[0].clientX));

  // Rebuild on resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { buildDots(); goTo(Math.min(current, maxIndex())); }, 150);
  });

  buildDots();
  startAutoplay();
})();

// ── FAQ accordion ────────────────────────────────
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-question')?.addEventListener('click',()=>{
    const open=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!open)item.classList.add('open');
  });
});

// ── Contact form — mailto ────
document.getElementById('contact-form-main')?.addEventListener('submit', (e) => {
  e.preventDefault();
  const form = e.currentTarget as HTMLFormElement;
  const fd = new FormData(form);
  const name    = fd.get('name')    || '';
  const email   = fd.get('email')   || '';
  const phone   = fd.get('phone')   || '';
  const service = fd.get('service') || '';
  const message = fd.get('message') || '';

  const subject = encodeURIComponent(`Zapytanie ze strony — ${name}`);
  const body    = encodeURIComponent(
    `Imię: ${name}\nEmail: ${email}\nTelefon: ${phone}\nUsługa: ${service}\n\nWiadomość:\n${message}`
  );

  window.location.href = `mailto:kontakt@ctrlzstudio.pl?subject=${subject}&body=${body}`;
});
</script>
