---
import Layout from '../layouts/Layout.astro';
import SharedNav from '../components/SharedNav.astro';
import SharedFooter from '../components/SharedFooter.astro';
---

<Layout
  title="O nas — CtrlZ Studio"
  description="Poznaj CtrlZ Studio — web development, SEO i SEM pod jednym dachem. Karol (dev), Dawid (SEO) i Kuba (SEM) tworzą projekty, które realnie zarabiają."
>
<SharedNav />

<main id="main-content">

<style>
/* ── HERO ──────────────────────────── */
.abn-hero {
  padding: 140px 0 72px;
  position: relative;
  overflow: hidden;
  background: var(--bg-base);
}
.abn-inner { max-width:1280px; margin:0 auto; padding:0 48px; }

/* ── MANIFESTO STRIP ─────────────────── */
.manifesto-wrap { max-width:1280px; margin:0 auto; padding:0 48px 72px; }
.manifesto-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:1px; background:rgba(255,255,255,.05);
  border-radius:18px; overflow:hidden;
  border:1px solid rgba(255,255,255,.05);
}
.manifesto-item {
  background:var(--bg-elevated);
  padding:36px 32px; transition:background .25s;
}
.manifesto-item:hover { background:rgba(124,107,255,.05); }
.manifesto-num {
  font-family:var(--font-display); font-size:42px; font-weight:800;
  letter-spacing:-.06em; line-height:1; margin-bottom:10px;
  background:var(--grad-hero); -webkit-background-clip:text;
  -webkit-text-fill-color:transparent; background-clip:text;
}
.manifesto-title { font-family:var(--font-display); font-size:16px; font-weight:700; color:#fff; margin-bottom:6px; }
.manifesto-desc  { font-size:13px; color:rgba(255,255,255,.36); line-height:1.65; }

/* ── TEAM SECTION ────────────────────── */
.team-wrap { max-width:1280px; margin:0 auto; padding:0 48px 72px; }
.team-label-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
/* Colored role labels */
.role-label {
  font-family: var(--font-display);
  font-size: clamp(24px,3vw,36px);
  font-weight: 800;
  letter-spacing: -.04em;
}
.role-label-dev  { color: #a78bfa; }
.role-label-seo  { color: #4ade80; }
.role-label-sem  { color: #fb923c; }
.role-sep {
  font-family: var(--font-display);
  font-size: clamp(24px,3vw,36px);
  font-weight: 800;
  color: rgba(255,255,255,.15);
}

/* ── KAROL CARD (expanded, full-width) ── */
.karol-card {
  background:rgba(255,255,255,.022);
  border:1px solid rgba(255,255,255,.08);
  border-radius:20px; overflow:hidden;
  display:grid; grid-template-columns:320px 1fr;
  margin-bottom:16px; transition:border-color .3s;
}
.karol-card:hover { border-color:rgba(124,107,255,.22); }

.karol-left {
  padding:44px 36px;
  background:linear-gradient(160deg,rgba(124,107,255,.08) 0%,rgba(99,102,241,.03) 100%);
  display:flex; flex-direction:column; justify-content:space-between;
  border-right:1px solid rgba(255,255,255,.06);
}
.role-badge {
  display:inline-flex; align-items:center; gap:7px;
  font-size:11px; font-weight:700; letter-spacing:.12em;
  text-transform:uppercase; padding:6px 14px;
  border-radius:100px; margin-bottom:24px; width:fit-content;
}
.badge-dev { background:rgba(124,107,255,.15); color:#c4b5fd; border:1px solid rgba(124,107,255,.3); }
.badge-seo { background:rgba(74,222,128,.1);   color:#86efac; border:1px solid rgba(74,222,128,.25); }
.badge-sem { background:rgba(251,146,60,.1);   color:#fed7aa; border:1px solid rgba(251,146,60,.25); }
.badge-collab { background:rgba(255,255,255,.06); color:rgba(255,255,255,.45); border:1px solid rgba(255,255,255,.12); }

.member-av {
  width:72px; height:72px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-display); font-size:26px; font-weight:800;
  color:#fff; margin-bottom:18px; flex-shrink:0;
}
.av-dev { background:linear-gradient(135deg,#7c6bff,#a78bfa); }
.av-seo { background:linear-gradient(135deg,#16a34a,#22c55e); }
.av-sem { background:linear-gradient(135deg,#ea580c,#f97316); }

.member-name  { font-family:var(--font-display); font-size:24px; font-weight:800; color:#fff; letter-spacing:-.03em; margin-bottom:3px; }
.member-title { font-size:13px; color:rgba(255,255,255,.36); margin-bottom:22px; }
.skill-tags   { display:flex; flex-wrap:wrap; gap:5px; }
.skill-tag    { font-size:11px; padding:3px 9px; border-radius:100px; border:1px solid rgba(255,255,255,.1); color:rgba(255,255,255,.4); }

.karol-right {
  padding:44px 52px;
  display:flex; flex-direction:column; gap:0;
}

/* Karol expanded content grid */
.karol-content { display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-bottom:32px; }
.karol-desc-lead {
  font-size:17px; color:rgba(255,255,255,.7);
  line-height:1.82; font-weight:300; grid-column:1/-1;
}
.karol-desc-lead strong { color:#fff; font-weight:600; }
.karol-section-title {
  font-family:var(--font-display); font-size:13px; font-weight:600;
  color:var(--violet-light); letter-spacing:.08em;
  text-transform:uppercase; margin-bottom:10px;
  display:flex; align-items:center; gap:8px;
}
.karol-section-title::after { content:''; flex:1; height:1px; background:rgba(124,107,255,.2); }
.karol-text {
  font-size:14.5px; color:rgba(255,255,255,.5);
  line-height:1.8; margin:0;
}
.karol-text strong { color:rgba(255,255,255,.78); font-weight:600; }

/* Stats row */
.karol-stats {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:12px; margin-bottom:28px;
}
.kstat {
  background:rgba(124,107,255,.06); border:1px solid rgba(124,107,255,.14);
  border-radius:12px; padding:16px; text-align:center;
}
.kstat-num {
  font-family:var(--font-display); font-size:26px; font-weight:800;
  letter-spacing:-.04em; color:#c4b5fd; line-height:1; margin-bottom:4px;
}
.kstat-label { font-size:11px; color:rgba(255,255,255,.3); line-height:1.4; }

/* Timeline */
.karol-timeline { display:flex; flex-direction:column; gap:0; }
.tl-item {
  display:flex; gap:16px; position:relative;
  padding-bottom:18px;
}
.tl-item:last-child { padding-bottom:0; }
.tl-left { display:flex; flex-direction:column; align-items:center; flex-shrink:0; }
.tl-dot {
  width:10px; height:10px; border-radius:50%;
  background:var(--violet); border:2px solid rgba(124,107,255,.4);
  flex-shrink:0; margin-top:5px;
  box-shadow:0 0 8px rgba(124,107,255,.4);
}
.tl-line {
  width:1px; flex:1; background:rgba(124,107,255,.15);
  margin:4px 0;
}
.tl-item:last-child .tl-line { display:none; }
.tl-year { font-size:11px; font-weight:600; color:var(--violet-light); width:36px; text-align:right; padding-top:3px; }
.tl-body h4 { font-family:var(--font-display); font-size:14px; font-weight:600; color:#fff; margin-bottom:2px; }
.tl-body p  { font-size:12px; color:rgba(255,255,255,.38); line-height:1.5; margin:0; }

/* Fun fact */
.fun-fact {
  display:flex; align-items:flex-start; gap:10px;
  padding:13px 16px; background:rgba(255,255,255,.025);
  border-radius:10px; border:1px solid rgba(255,255,255,.06);
  font-size:13px; color:rgba(255,255,255,.42); line-height:1.6;
}

/* ── COLLAB CARDS (smaller) ─────────── */
.collab-header {
  display:flex; align-items:center; gap:24px;
  margin: 48px 0 28px;
  position: relative;
}
.collab-sep {
  height:1px; flex:1; background:rgba(255,255,255,.07);
}
.collab-label {
  font-family: var(--font-display);
  font-size: 22px; font-weight: 800;
  letter-spacing: -.02em;
  color: rgba(255,255,255,.22);
  white-space:nowrap;
  display: flex;
  align-items: center;
  gap: 10px;
}
.collab-label::before {
  content: '';
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(124,107,255,.5);
  box-shadow: 0 0 10px rgba(124,107,255,.4);
}
.collab-grid { display:grid; grid-template-columns:1fr; gap:16px; }
.collab-card {
  background:rgba(255,255,255,.022);
  border:1px solid rgba(255,255,255,.07);
  border-radius:18px; overflow:hidden;
  display:grid; grid-template-columns:240px 1fr;
  transition:border-color .3s;
}
.collab-card:hover { border-color:rgba(124,107,255,.18); }

.collab-left {
  padding:32px 28px;
  display:flex; flex-direction:column; justify-content:space-between;
  border-right:1px solid rgba(255,255,255,.06);
}
.collab-right { padding:32px; display:flex; flex-direction:column; gap:16px; justify-content:center; }
.collab-desc { font-size:14px; color:rgba(255,255,255,.5); line-height:1.75; }
.collab-desc strong { color:rgba(255,255,255,.78); font-weight:600; }
.collab-stat { font-size:12px; color:rgba(255,255,255,.3); display:flex; flex-direction:column; gap:8px; }
.cstat-row { display:flex; align-items:baseline; gap:10px; flex-wrap:wrap; }
.cstat-num { font-family:var(--font-display); font-size:20px; font-weight:700; min-width:44px; flex-shrink:0; line-height:1.2; }
.cstat-label { font-size:12px; color:rgba(255,255,255,.55); line-height:1.4; flex:1; min-width:0; }
.num-seo { color:#4ade80; }
.num-sem { color:#fb923c; }
.ext-link {
  display:inline-flex; align-items:center; gap:7px;
  font-size:12px; font-weight:500; color:rgba(255,255,255,.45);
  background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.09);
  border-radius:100px; padding:7px 14px; transition:all .2s;
  text-decoration:none; width:fit-content;
}
.ext-link:hover { color:#fff; background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.2); }
.ext-link svg { width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round; }

/* ── WHY IT WORKS ────────────────────── */
.why-wrap { max-width:1280px; margin:0 auto; padding:0 48px 72px; }
.why-inner {
  background:rgba(255,255,255,.02);
  border:1px solid rgba(255,255,255,.07);
  border-radius:20px; padding:52px;
}
.why-grid { display:grid; grid-template-columns:1fr 1fr; gap:52px; align-items:start; }
.why-text p { font-size:16px; color:rgba(255,255,255,.5); line-height:1.8; margin-bottom:20px; }
.why-text p strong { color:rgba(255,255,255,.78); font-weight:600; }
.why-cards { display:flex; flex-direction:column; gap:10px; }
.why-card {
  display:flex; align-items:flex-start; gap:14px;
  padding:16px 18px; border-radius:12px; border:1px solid;
  transition: transform .25s ease, border-color .25s, background .25s;
  cursor: default;
}
.why-card:hover { transform: translateX(6px); }
.why-card-dev { background:rgba(124,107,255,.05); border-color:rgba(124,107,255,.14); }
.why-card-dev:hover { background:rgba(124,107,255,.1); border-color:rgba(124,107,255,.32); }
.why-card-seo { background:rgba(74,222,128,.04);  border-color:rgba(74,222,128,.12); }
.why-card-seo:hover { background:rgba(74,222,128,.09); border-color:rgba(74,222,128,.28); }
.why-card-sem { background:rgba(251,146,60,.04);   border-color:rgba(251,146,60,.12); }
.why-card-sem:hover { background:rgba(251,146,60,.1); border-color:rgba(251,146,60,.3); }
.why-card-icon {
  width:34px; height:34px; border-radius:9px;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
.wci-dev { background:rgba(124,107,255,.18); }
.wci-seo { background:rgba(74,222,128,.14); }
.wci-sem { background:rgba(251,146,60,.14); }
.why-card-icon svg { width:16px;height:16px;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round; }
.wci-dev svg { stroke:#c4b5fd; }
.wci-seo svg { stroke:#86efac; }
.wci-sem svg { stroke:#fdba74; }
.why-card h4 { font-family:var(--font-display); font-size:14px; font-weight:600; color:#fff; margin-bottom:3px; }
.why-card p  { font-size:12.5px; color:rgba(255,255,255,.38); line-height:1.55; margin:0; }

/* ── CHARTS ──────────────────────────── */
.charts-wrap { max-width:1280px; margin:0 auto; padding:0 48px 72px; }
.charts-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.chart-card {
  background:rgba(255,255,255,.022);
  border:1px solid rgba(255,255,255,.07);
  border-radius:16px; padding:24px 24px 20px;
}
.chart-card-title { font-family:var(--font-display); font-size:14px; font-weight:600; color:#fff; margin-bottom:4px; }
.chart-card-sub   { font-size:11px; color:rgba(255,255,255,.3); margin-bottom:20px; }

/* Bar chart */
.bar-chart { display:flex; flex-direction:column; gap:10px; }
.bar-row { display:flex; align-items:center; gap:10px; }
.bar-label { font-size:11px; color:rgba(255,255,255,.35); width:60px; flex-shrink:0; }
.bar-track { flex:1; height:7px; background:rgba(255,255,255,.06); border-radius:4px; overflow:hidden; }
.bar-fill  { height:100%; border-radius:4px; }
.bar-val   { font-size:11px; font-weight:600; width:36px; text-align:right; flex-shrink:0; }

/* Donut chart (SVG) */
.donut-wrap { display:flex; align-items:center; gap:20px; }
.donut-legend { display:flex; flex-direction:column; gap:8px; flex:1; }
.legend-item { display:flex; align-items:center; gap:7px; font-size:12px; color:rgba(255,255,255,.45); }
.legend-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

/* Line chart (SVG) */
.line-chart-wrap { position:relative; }

/* ── CTA — 1280px ───────────────────── */
.abn-cta { max-width:1280px; margin:0 auto; padding:0 48px 96px; }
.abn-cta-inner {
  background:linear-gradient(135deg,rgba(124,107,255,.1),rgba(236,72,153,.05));
  border:1px solid rgba(124,107,255,.22);
  border-radius:24px; padding:72px;
  text-align:center; position:relative; overflow:hidden;
}
.abn-cta-inner::before {
  content:''; position:absolute; inset:0;
  background:radial-gradient(ellipse at center,rgba(124,107,255,.12) 0%,transparent 65%);
  pointer-events:none;
}
.abn-cta-title {
  font-family:var(--font-display);
  font-size:clamp(32px,4vw,52px); font-weight:800;
  letter-spacing:-.04em; color:#fff; margin-bottom:18px; position:relative;
}
.abn-cta-sub {
  font-size:16px; color:rgba(255,255,255,.45);
  max-width:520px; margin:0 auto 36px; line-height:1.7; position:relative;
}
.abn-cta-btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; position:relative; }

/* Responsive */
@media(max-width:1100px){
  .collab-card { grid-template-columns:1fr; }
  .why-grid { grid-template-columns:1fr; gap:36px; }
  .charts-grid { grid-template-columns:1fr 1fr; }
  .karol-card { grid-template-columns:260px 1fr; }
  .karol-content { grid-template-columns:1fr; }
  .karol-stats { grid-template-columns:repeat(2,1fr); }
}
@media(max-width:768px){
  .abn-inner,.manifesto-wrap,.team-wrap,.why-wrap,.charts-wrap,.abn-cta { padding-left:20px; padding-right:20px; }
  .karol-card { grid-template-columns:1fr; }
  .karol-left { border-right:none; border-bottom:1px solid rgba(255,255,255,.06); padding:28px 24px 24px; }
  .karol-right { padding:28px 24px; }
  .collab-card { grid-template-columns:1fr; }
  .collab-left { border-right:none; border-bottom:1px solid rgba(255,255,255,.06); padding:24px; }
  .collab-right { padding:24px; }
  .manifesto-grid { grid-template-columns:1fr; }
  .karol-stats { grid-template-columns:repeat(2,1fr); }
  .charts-grid { grid-template-columns:1fr; }
  .why-inner { padding:32px 20px; }
  .abn-cta-inner { padding:44px 24px; }
}
</style>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="abn-hero">
  <div class="orb orb-1" style="opacity:.5"></div>
  <div class="orb orb-2" style="opacity:.35"></div>
  <div class="orb" style="width:380px;height:380px;background:radial-gradient(circle,rgba(236,72,153,.1) 0%,transparent 65%);bottom:-80px;right:8%;filter:blur(60px)"></div>
  <div class="grid-bg"></div>
  <div class="abn-inner" style="position:relative">
    <div class="eyebrow" style="margin-bottom:20px" id="ah-ey">Poznaj nas</div>
    <h1 class="display-xl" style="margin-bottom:20px" id="ah-h">
      Pięciu ludzi,<br>
      jeden cel <span class="grad">projekty</span><br>
      <span class="italic-light">które zarabiają.</span>
    </h1>
    <p id="ah-p" style="font-size:17px;color:rgba(255,255,255,.44);max-width:560px;line-height:1.75;font-weight:300">
      CtrlZ Studio to nie korporacja z działem sprzedaży. To DEV, SEO i SEM, którzy razem ogarniają projekty od designu przez wdrożenie po migracje i utrzymanie.
    </p>
  </div>
</section>

<!-- ═══════════════ MANIFESTO ═══════════════ -->
<div class="manifesto-wrap">
  <div class="manifesto-grid">
    <div class="manifesto-item js-reveal">
      <div class="manifesto-num" id="mn1">0</div>
      <div class="manifesto-title">Zrealizowanych projektów</div>
      <div class="manifesto-desc">Od landing page po rozbudowane sklepy e-commerce i aplikacje webowe.</div>
    </div>
    <div class="manifesto-item js-reveal" data-delay="0.08">
      <div class="manifesto-num" id="mn2">0</div>
      <div class="manifesto-title">Lat doświadczenia łącznie</div>
      <div class="manifesto-desc">Każdy z nas przez lata szlifował swoje rzemiosło zanim zdecydowaliśmy się połączyć siły.</div>
    </div>
    <div class="manifesto-item js-reveal" data-delay="0.16">
      <div class="manifesto-num" id="mn3">0</div>
      <div class="manifesto-title">Aktywnych kampanii SEM</div>
      <div class="manifesto-desc">Zarządzamy kampaniami Google i Meta Ads równolegle, w różnych branżach.</div>
    </div>
  </div>
</div>

<!-- ═══════════════ TEAM ═══════════════ -->
<div class="team-wrap">
  <!-- Colored title -->
  <div class="eyebrow js-reveal" style="margin-bottom:12px">Nasz zespół</div>
  <div class="team-label-row js-reveal" style="margin-bottom:32px">
    <span class="role-label role-label-dev">DEV</span>
    <span class="role-sep">·</span>
    <span class="role-label role-label-seo">SEO</span>
    <span class="role-sep">·</span>
    <span class="role-label role-label-sem">SEM</span>
  </div>

  <!-- ─── KAROL (expanded) ─── -->
  <div class="karol-card js-scale" id="card-dev">
    <div class="karol-left">
      <div>
        <div class="role-badge badge-dev">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Web Development
        </div>
        <div class="member-av av-dev">K</div>
        <div class="member-name">Karol</div>
        <div class="member-title">Founder · Lead Dev & Designer</div>
      </div>
      <div>
        <div style="font-size:11px;color:rgba(255,255,255,.25);letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px">Stack</div>
        <div class="skill-tags">
          <span class="skill-tag">WordPress</span>
          <span class="skill-tag">WooCommerce</span>
          <span class="skill-tag">IdoSell</span>
          <span class="skill-tag">Figma</span>
          <span class="skill-tag">GSAP</span>
          <span class="skill-tag">Astro.js</span>
          <span class="skill-tag">Next.js</span>
          <span class="skill-tag">PHP</span>
          <span class="skill-tag">SCSS</span>
          <span class="skill-tag">TypeScript</span>
        </div>
      </div>
    </div>

    <div class="karol-right">
      <!-- Lead paragraph -->
      <p class="karol-desc-lead" style="margin-bottom:28px">
        Zaczynałem od grafiki komputerowej — skończyłem na pełnym stacku od makiet w Figmie po deployment na serwerze. <strong>Przez 7 lat pracowałem przy ponad 250+ projektach</strong> — od prostych landing page'y po rozbudowane sklepy e-commerce.
      </p>

      <!-- 4 stats -->
      <div class="karol-stats" style="margin-bottom:28px">
        <div class="kstat"><div class="kstat-num">7+</div><div class="kstat-label">lat doświadczenia</div></div>
        <div class="kstat"><div class="kstat-num">250+</div><div class="kstat-label">projektów</div></div>
        <div class="kstat"><div class="kstat-num">90+</div><div class="kstat-label">Lighthouse score</div></div>
        <div class="kstat"><div class="kstat-num">99%</div><div class="kstat-label">zadowolonych klientów</div></div>
      </div>

      <!-- Two-column detail -->
      <div class="karol-content" style="margin-bottom:28px">
        <div>
          <div class="karol-section-title">Specjalizacje</div>
          <p class="karol-text">
