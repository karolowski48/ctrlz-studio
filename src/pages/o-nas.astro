<script>
import { initPage } from '../utils/pageInit';
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);
initPage();

// Reading progress
const bar = document.createElement('div');
bar.className = 'reading-progress';
document.body.prepend(bar);
window.addEventListener('scroll',()=>{
  const d=document.documentElement;
  bar.style.width=Math.min((window.scrollY/(d.scrollHeight-d.clientHeight))*100,100)+'%';
},{passive:true});

// Hero entrance
const tl = gsap.timeline({defaults:{ease:'power3.out'}});
tl.fromTo('#ah-ey',{opacity:0,y:12},{opacity:1,y:0,duration:.6},.25)
  .fromTo('#ah-h', {opacity:0,y:32},{opacity:1,y:0,duration:.9},'-=.4')
  .fromTo('#ah-p', {opacity:0,y:18},{opacity:1,y:0,duration:.7},'-=.5');

// Scroll reveals
document.querySelectorAll<HTMLElement>('.js-reveal').forEach(el=>{
  const d=parseFloat(el.dataset.delay||'0');
  gsap.fromTo(el,{opacity:0,y:26},{opacity:1,y:0,duration:.8,ease:'power3.out',delay:d,
    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}});
});
document.querySelectorAll<HTMLElement>('.js-scale').forEach(el=>{
  const d=parseFloat(el.dataset.delay||'0');
  gsap.fromTo(el,{opacity:0,y:32},{opacity:1,y:0,duration:.9,ease:'power3.out',delay:d,
    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}});
});

// Manifesto count-up
const mnData = [{id:'mn1',target:250,suffix:'+'},{id:'mn2',target:15,suffix:'+'},{id:'mn3',target:20,suffix:''}];
mnData.forEach(({id,target,suffix})=>{
  const el = document.getElementById(id)!;
  let done=false;
  ScrollTrigger.create({trigger:el,start:'top 85%',once:true,onEnter:()=>{
    if(done)return;done=true;
    const obj={v:0};
    gsap.to(obj,{v:target,duration:1.8,ease:'power2.out',
      onUpdate(){el.textContent=Math.round(obj.v)+suffix;}});
  }});
});

// Bar chart animation
document.querySelectorAll<HTMLElement>('.bar-fill').forEach(bar=>{
  const to=parseFloat(bar.dataset.to||'0');
  let done=false;
  ScrollTrigger.create({trigger:bar,start:'top 88%',once:true,onEnter:()=>{
    if(done)return;done=true;
    gsap.to(bar,{width:to+'%',duration:1.2,ease:'power3.out',delay:.1});
  }});
});

// Donut chart animation
const donutData=[
  {id:'donut-seo',  circ:301.6},
  {id:'donut-sem',  circ:201.1},
  {id:'donut-direct',circ:129.3},
  {id:'donut-other', circ:86.4},
];
let donutDone=false;
ScrollTrigger.create({trigger:'#donut-svg',start:'top 85%',once:true,onEnter:()=>{
  if(donutDone)return;donutDone=true;
  const totalCirc=301.6+201.1+129.3+86.4; // ≈ 718.4 ≈ 2π×48×2.38 — actual circumf = 2π×48 ≈ 301.6
  // actual circumference of r=48: 2*π*48 ≈ 301.6
  // so full circle = 301.6 total → use dasharray trick
  let offset=0;
  donutData.forEach(({id,circ},i)=>{
    const el=document.getElementById(id) as SVGCircleElement|null;
    if(!el)return;
    gsap.to(el,{
      attr:{'stroke-dasharray':`${circ} ${301.6*2-circ}`},
      duration:1.2,ease:'power3.out',delay:i*.15
    });
  });
}});

// Card tilt
document.querySelectorAll<HTMLElement>('.karol-card,.collab-card').forEach(card=>{
  card.addEventListener('mousemove',(e:MouseEvent)=>{
    const r=card.getBoundingClientRect();
    gsap.to(card,{
      rotateY:((e.clientX-r.left)/r.width-.5)*5,
      rotateX:-((e.clientY-r.top)/r.height-.5)*3,
      duration:.4,ease:'power2.out',transformPerspective:1400
    });
  });
  card.addEventListener('mouseleave',()=>{
    gsap.to(card,{rotateY:0,rotateX:0,duration:.5,ease:'power3.out'});
  });
});
</script>
