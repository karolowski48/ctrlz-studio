<script>
// ═══════════════ SEM CALCULATOR LOGIC ════════════════
// Packages based on the pricing table:
// Packet 1 (Pozyskiwanie kontaktów): budget < 6k
//   M1: acc 300 + meta 600 + gads 500 + treści 500 = 1900
//   M2: acc 300 + meta 600 + gads 500 = 1400
// Packet 2 (Mały e-commerce, ~6k budżetu):
//   M1: acc 300 + meta 600 + gads 500 + treści ecomm 300 = 1700
//   M2: acc 300 + meta 600 + gads 500 = 1400
// Packet 4 (Średni e-commerce, 6-30k):
//   M1: acc 400 + meta 1000 + gads 800 + treści 500 + strategia 500 = 3200
//   M2: acc 400 + meta 1000 + gads 800 = 2200
// Packet 3 (Duży e-commerce, 30k+):
//   M1: acc 500 + meta 2000 + gads 1600 + treści 500 + strategia 1000 = 5600
//   M2: acc 500 + meta 2000 + gads 1600 = 4100

interface SemPkg {
  name: string;
  range: string;
  m1: { acc:number; gads:number; meta:number; tresci:number; strat:number; };
  m2: { acc:number; gads:number; meta:number; tresci:number; strat:number; };
  individual?: boolean;
}

const SEM_BUDGETS = [1000,2000,3000,5000,8000,10000,15000,20000,30000];

// ACC merged 50/50 into gads + meta (per Kuba's request)
// Google Ads shown first (higher amount)
const SEM_PACKAGES: SemPkg[] = [
  // idx 0-2: Pozyskiwanie kontaktów (budget ≤ 5k)
  // acc=300 → gads+150=650, meta+150=750 | M1: 650+750+500=1900, M2: 650+750=1400
  {
    name: 'Pozyskiwanie kontaktów',
    range: 'Budżet reklamowy: do 5 000 zł/mies.',
    m1: {acc:0, gads:650, meta:750, tresci:500, strat:0},
    m2: {acc:0, gads:650, meta:750, tresci:0,   strat:0},
  },
  // idx 3-4: Mały e-commerce (5k-10k)
  // acc=300 → gads+150=650, meta+150=750 | M1: 650+750+300=1700, M2: 650+750=1400
  {
    name: 'Mały e-commerce',
    range: 'Budżet reklamowy: 5 000–10 000 zł/mies.',
    m1: {acc:0, gads:650, meta:750, tresci:300, strat:0},
    m2: {acc:0, gads:650, meta:750, tresci:0,   strat:0},
  },
  // idx 5-7: Średni e-commerce (10k-30k)
  // acc=400 → gads+200=1000, meta+200=1200 | M1: 1000+1200+500+500=3200, M2: 1000+1200=2200
  {
    name: 'Średni e-commerce',
    range: 'Budżet reklamowy: 10 000–30 000 zł/mies.',
    m1: {acc:0, gads:1000, meta:1200, tresci:500, strat:500},
    m2: {acc:0, gads:1000, meta:1200, tresci:0,   strat:0},
  },
  // idx 8: Duży e-commerce (30k+)
  // acc=500 → gads+250=1850, meta+250=2250 | M1: 1850+2250+500+1000=5600, M2: 1850+2250=4100
  {
    name: 'Duży e-commerce',
    range: 'Budżet reklamowy: 30 000+ zł/mies.',
    m1: {acc:0, gads:1850, meta:2250, tresci:500, strat:1000},
    m2: {acc:0, gads:1850, meta:2250, tresci:0,   strat:0},
    individual: true,
  },
];

function getPkgForSlider(idx: number): SemPkg {
  if (idx <= 2) return SEM_PACKAGES[0];
  if (idx <= 4) return SEM_PACKAGES[1];
  if (idx <= 7) return SEM_PACKAGES[2];
  return SEM_PACKAGES[3];
}

let semMonth = 1;

function fmt(n: number): string {
  return n > 0 ? n.toLocaleString('pl-PL') + ' zł' : '—';
}

function semRender(sliderIdx: number) {
  const pkg = getPkgForSlider(sliderIdx);
  const data = semMonth === 1 ? pkg.m1 : pkg.m2;
  const total = data.acc + data.meta + data.gads + data.tresci + data.strat;

  // Budget display
  const budgetEl = document.getElementById('sem-budget-disp')!;
  const bval = SEM_BUDGETS[sliderIdx];
  budgetEl.textContent = sliderIdx === 8 ? '30 000+ zł' :
    bval.toLocaleString('pl-PL') + ' zł';

  // Package info
  document.getElementById('sem-pkg-name')!.textContent = pkg.name;
  document.getElementById('sem-pkg-range')!.textContent = pkg.range;

  // Breakdown
  document.getElementById('sb-gads')!.textContent  = fmt(data.gads);
  document.getElementById('sb-meta')!.textContent  = fmt(data.meta);
  document.getElementById('sb-tresci')!.textContent= fmt(data.tresci);
  document.getElementById('sb-strat')!.textContent = fmt(data.strat);
  document.getElementById('sem-total')!.textContent= total.toLocaleString('pl-PL') + ' zł';
  document.getElementById('sem-month-label')!.textContent =
    `Koszt obsługi — Miesiąc ${semMonth === 1 ? '1' : '2+'}`;

  // Individual
  const indEl = document.getElementById('sem-individual')!;
  const pkgEl = document.getElementById('sem-package')!;
  indEl.classList.toggle('visible', !!pkg.individual);
  pkgEl.style.display = pkg.individual ? 'none' : 'block';
}

(window as any).semSetMonth = function(m: number) {
  semMonth = m;
  document.getElementById('tab-m1')!.classList.toggle('active', m === 1);
  document.getElementById('tab-m2')!.classList.toggle('active', m === 2);
  const sl = document.getElementById('sem-slider') as HTMLInputElement;
  semRender(parseInt(sl.value));
};

const semSlider = document.getElementById('sem-slider') as HTMLInputElement;
semSlider.addEventListener('input', () => semRender(parseInt(semSlider.value)));

// Init
semRender(1);
</script>

<script>
import { initPage } from '../utils/pageInit';
import gsap from 'gsap';
initPage();

// ════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════
type ProjectType = 'landing' | 'firmowa' | 'sklep' | 'custom';
type TechType    = 'wp' | 'next';

const state = {
  type:         'landing' as ProjectType,
  tech:         'wp'      as TechType,
  basePrice:    2000,  // landing default
  isIndividual: false,
  addonTotal:   0,
  addonLabels:  [] as string[],
};

// ════════════════════════════════════════════
// PRICING TABLES
// ════════════════════════════════════════════
// Landing: base price range, no size tiers
const LANDING_BASE = { low: 2000, high: 3000 };

// Firmowa: per tier
const FIRMOWA_TIERS: Record<string,number> = {
  f1: 4000, f2: 5500, f3: 6800,
};

// Sklep: per tier
const SKLEP_TIERS: Record<string,number> = {
  s1: 8000, s2: 11000, s3: 15000, s4: 0,
};

// Custom: base
const CUSTOM_BASE = 12000;

// ════════════════════════════════════════════
// HELPERS
// ════════════════════════════════════════════
function fmt(n: number): string {
  return n.toLocaleString('pl-PL') + ' zł';
}
function animVal(el: HTMLElement, val: string) {
  gsap.fromTo(el, {opacity:.3,y:-5}, {opacity:1,y:0,duration:.28,ease:'power2.out'});
  el.textContent = val;
}
function getActiveSizePrice(): number {
  if (state.type === 'landing') return LANDING_BASE.low;
  if (state.type === 'firmowa') return FIRMOWA_DATA[firmowaSizeIdx]?.price ?? 4000;
  if (state.type === 'sklep')   return SKLEP_DATA[sklepSizeIdx]?.price ?? 8000;
  return CUSTOM_BASE;
}
function getSizeLabel(): string {
  if (state.type === 'landing')  return 'One-page';
  if (state.type === 'firmowa') return FIRMOWA_DATA[firmowaSizeIdx]?.label ?? '1–3 podstrony';
  if (state.type === 'sklep')   return SKLEP_DATA[sklepSizeIdx]?.label ?? '1–3 podstrony';
  return 'Indywidualny';
}

// ════════════════════════════════════════════
// CALCULATE & RENDER
// ════════════════════════════════════════════
function calc() {
  const base   = getActiveSizePrice();
  const isInd  = (state.type === 'custom')
    || (state.type === 'sklep'   && SKLEP_DATA[sklepSizeIdx]?.individual === true)
    || (state.type === 'firmowa' && FIRMOWA_DATA[firmowaSizeIdx]?.individual === true);
  state.isIndividual = isInd;

  const techMult = state.tech === 'next' ? 1.6 : 1.0;

  const low = Math.round(base * techMult / 100) * 100;
  const high  = Math.round(low * 1.25 / 100) * 100;
  const total = low + state.addonTotal;
  const totalHigh = high + state.addonTotal;

  // Update result card
  const priceEl = document.getElementById('r-price')!;
  const rangeEl = document.getElementById('r-range')!;
  const indEl   = document.getElementById('r-individual')!;

  if (isInd) {
    animVal(priceEl, 'Wycena indyw.');
    animVal(rangeEl, 'Skontaktuj się');
    indEl.style.display = 'block';
    priceEl.style.fontSize = '28px';
  } else {
    animVal(priceEl, fmt(total));
    animVal(rangeEl, '— ' + fmt(totalHigh));
    indEl.style.display = 'none';
    priceEl.style.fontSize = '';
  }

  // Row labels
  const typeNames: Record<string,string> = {
    landing: 'Landing Page', firmowa: 'Strona firmowa', sklep: 'Sklep internetowy', custom: 'Custom / Aplikacja'
  };
  animVal(document.getElementById('r-type')!,   typeNames[state.type]);
  animVal(document.getElementById('r-tech')!,   state.tech === 'next' ? 'Next.js / Astro.js' : 'WordPress');
  animVal(document.getElementById('r-size')!,   getSizeLabel());

  // Addons
  const addonsRow = document.getElementById('r-addons-row')!;
  if (state.addonLabels.length > 0) {
    addonsRow.style.display = 'flex';
    animVal(document.getElementById('r-addons')!, '+' + fmt(state.addonTotal));
  } else {
    addonsRow.style.display = 'none';
  }
}

// ════════════════════════════════════════════
// SIZE GROUP VISIBILITY
// ════════════════════════════════════════════
function showSizeGroup(type: ProjectType) {
  ['landing','firmowa','sklep','custom'].forEach(t => {
    const el = document.getElementById(`sg-${t}`)!;
    el.classList.toggle('visible', t === type);
  });
  // Update step title
  const titles: Record<string,string> = {
    landing: 'One-page', firmowa: 'Liczba podstron', sklep: 'Liczba podstron', custom: 'Zakres projektu'
  };
  document.getElementById('size-step-title')!.textContent = type === 'landing'
    ? 'Format projektu' : 'Liczba podstron';
}

// ════════════════════════════════════════════
// TECH STACK LOCK (sklep & custom → WP only)
// ════════════════════════════════════════════
function updateTechAvailability(type: ProjectType) {
  const nextOpt   = document.getElementById('opt-next')!;
  const wpInput   = document.querySelector<HTMLInputElement>('input[name="tech"][value="wp"]')!;
  const techNote  = document.getElementById('tech-note')!;
  const locked    = type === 'sklep' || type === 'custom';

  nextOpt.classList.toggle('disabled', locked);
  techNote.style.display = 'none';

  if (locked && state.tech === 'next') {
    wpInput.checked = true;
    state.tech = 'wp';
    techNote.style.display = 'block';
  }
}

// ════════════════════════════════════════════
// EVENT LISTENERS
// ════════════════════════════════════════════

// Type
document.querySelectorAll<HTMLInputElement>('input[name="type"]').forEach(inp => {
  inp.addEventListener('change', () => {
    state.type = inp.value as ProjectType;
    showSizeGroup(state.type);
    updateTechAvailability(state.type);
    // Reset slider positions
    firmowaSizeIdx = 0; sklepSizeIdx = 0;
    const sf = document.getElementById('slider-firmowa') as HTMLInputElement|null;
    const ss = document.getElementById('slider-sklep')   as HTMLInputElement|null;
    if(sf) sf.value='0'; if(ss) ss.value='0';
    updateSliderLabels('sl-firmowa-labels',0);
    updateSliderLabels('sl-sklep-labels',0);
    calc();
    document.getElementById('step-1')!.classList.add('active');
    document.getElementById('step-4')!.classList.add('active');
  });
});

// Tech
document.querySelectorAll<HTMLInputElement>('input[name="tech"]').forEach(inp => {
  inp.addEventListener('change', () => {
    state.tech = inp.value as TechType;
    calc();
  });
});

// ── Size sliders ─────────────────────────────────────
const FIRMOWA_DATA = [
  {price: 4000, label: '1–3 podstrony', desc: 'Strona główna + 2 podstrony (np. O nas, Kontakt).', individual: false},
  {price: 5500, label: '4–8 podstron',  desc: 'Rozbudowana strona firmowa z ofertą, blogiem, referencjami.', individual: false},
  {price: 6800, label: '9–15 podstron', desc: 'Portal firmowy, wielobranżowa strona, rozbudowane portfolio.', individual: false},
  {price: 0,    label: 'Powyżej 15',    desc: 'Indywidualna wycena — skontaktuj się z nami bezpośrednio.', individual: true},
];
const SKLEP_DATA = [
  {price: 8000,  label: '1–3 podstrony',   desc: 'Sklep z gotowym motywem, strona główna + do 3 dodatkowych.', individual: false},
  {price: 11000, label: '4–8 podstron',    desc: 'Custom motyw, kategorie, blogi, landing dla kampanii.', individual: false},
  {price: 15000, label: '9–15 podstron',   desc: 'Rozbudowany sklep premium z konfiguratorem, filtrowaniem, wishlistą.', individual: false},
  {price: 0,     label: 'Powyżej 15',      desc: 'Indywidualna wycena — skontaktuj się z nami bezpośrednio.', individual: true},
];

let firmowaSizeIdx = 0;
let sklepSizeIdx   = 0;

function updateSliderLabels(labelsId: string, activeIdx: number) {
  document.querySelectorAll<HTMLElement>(`#${labelsId} .slider-label`).forEach((el, i) => {
    el.classList.toggle('active', i === activeIdx);
  });
}

const slFirmowa = document.getElementById('slider-firmowa') as HTMLInputElement | null;
if (slFirmowa) {
  slFirmowa.addEventListener('input', () => {
    firmowaSizeIdx = parseInt(slFirmowa.value);
    updateSliderLabels('sl-firmowa-labels', firmowaSizeIdx);
    const desc = document.getElementById('sl-firmowa-desc');
    if (desc) desc.textContent = FIRMOWA_DATA[firmowaSizeIdx].desc;
    calc();
  });
}

const slSklep = document.getElementById('slider-sklep') as HTMLInputElement | null;
if (slSklep) {
  slSklep.addEventListener('input', () => {
    sklepSizeIdx = parseInt(slSklep.value);
    updateSliderLabels('sl-sklep-labels', sklepSizeIdx);
    const desc = document.getElementById('sl-sklep-desc');
    if (desc) desc.textContent = SKLEP_DATA[sklepSizeIdx].desc;
    calc();
  });
}

// Addons (with SEO mutex)
document.querySelectorAll<HTMLElement>('.addon').forEach(addon => {
  addon.addEventListener('click', () => {
    if (addon.classList.contains('dimmed')) return;

    const isChecked = addon.classList.toggle('checked');
    const price     = parseInt(addon.dataset.price || '0');
    const label     = addon.dataset.label || '';
    const mutexId   = addon.dataset.mutex;

    if (isChecked) {
      state.addonTotal += price;
      state.addonLabels.push(label);
      // Dim the mutex partner
      if (mutexId) {
        const partner = document.getElementById(mutexId)!;
        partner.classList.add('dimmed');
        // Uncheck partner if it was checked
        if (partner.classList.contains('checked')) {
          partner.classList.remove('checked');
          const partnerPrice = parseInt(partner.dataset.price || '0');
          const partnerLabel = partner.dataset.label || '';
          state.addonTotal -= partnerPrice;
          state.addonLabels = state.addonLabels.filter(l => l !== partnerLabel);
        }
      }
    } else {
      state.addonTotal -= price;
      state.addonLabels = state.addonLabels.filter(l => l !== label);
      // Re-enable mutex partner
      if (mutexId) {
        document.getElementById(mutexId)!.classList.remove('dimmed');
      }
    }
    calc();
  });
});

// Step highlight on interaction
document.querySelectorAll('.calc-step').forEach(step => {
  step.addEventListener('click', () => {
    document.querySelectorAll('.calc-step').forEach(s => s.classList.remove('active'));
    step.classList.add('active');
  });
});

// Form submit — mailto
document.getElementById('calc-form')!.addEventListener('submit', e => {
  e.preventDefault();
  const form     = e.currentTarget as HTMLFormElement;
  const fd       = new FormData(form);
  const name     = fd.get('name')    as string || '';
  const email    = fd.get('email')   as string || '';
  const phone    = fd.get('phone')   as string || '';
  const company  = fd.get('company') as string || '';
  const priceText = document.getElementById('r-price')!.textContent || '';

  const subject = encodeURIComponent(`Zapytanie o wycenę — ${name} — ${priceText}`);
  const body    = encodeURIComponent(
    `Imię: ${name}\nEmail: ${email}\nTelefon: ${phone}\nFirma: ${company}\n\nOrientacyjna wycena kalkulatora: ${priceText}\n\n---\nWysłano z kalkulatora wyceny ctrlzstudio.pl`
  );
  window.location.href = `mailto:kontakt@ctrlzstudio.pl?subject=${subject}&body=${body}`;
});

// ════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════
showSizeGroup('landing');
updateTechAvailability('landing');
calc();

// Entrance animations
gsap.fromTo('.calc-hero h1',    {opacity:0,y:28},{opacity:1,y:0,duration:.9,ease:'power3.out',delay:.2});
gsap.fromTo('.calc-hero-sub',   {opacity:0,y:18},{opacity:1,y:0,duration:.7,ease:'power3.out',delay:.38});
gsap.fromTo('.calc-step',       {opacity:0,y:20},{opacity:1,y:0,duration:.6,ease:'power3.out',stagger:.07,delay:.5});
gsap.fromTo('.calc-result',     {opacity:0,x:20},{opacity:1,x:0,duration:.7,ease:'power3.out',delay:.65});
</script>
