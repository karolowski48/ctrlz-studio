---
import Layout from '../layouts/Layout.astro';
import SharedNav from '../components/SharedNav.astro';
import SharedFooter from '../components/SharedFooter.astro';
---

<Layout
  title="Kalkulator wyceny — CtrlZ Studio"
  description="Oblicz orientacyjny koszt swojego projektu w 2 minuty. Strony firmowe, sklepy WooCommerce, landing pages — z realnymi widełkami cenowymi."
>
<SharedNav />

<main id="main-content">

<style>
/* ── HERO ─────────────────────────────── */
.calc-hero {
  padding: 140px 0 56px;
  text-align: center;
  position: relative;
  overflow: hidden;
  background: var(--bg-base);
}
.calc-hero-sub {
  font-size: 16px;
  color: rgba(255,255,255,.42);
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.7;
  font-weight: 300;
}

/* ── LAYOUT ────────────────────────────── */
.calc-wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 48px 96px;
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 48px;
  align-items: start;
  background: var(--bg-base);
}

/* ── STEPS ─────────────────────────────── */
.calc-steps { display: flex; flex-direction: column; gap: 24px; }

.calc-step {
  background: rgba(255,255,255,.022);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 18px;
  padding: 28px 32px;
  transition: border-color .25s;
}
.calc-step.active { border-color: rgba(124,107,255,.35); background: rgba(124,107,255,.03); }

.step-head {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 22px;
}
.step-num {
  width: 28px; height: 28px;
  min-width: 28px; min-height: 28px;
  border-radius: 50%;
  background: rgba(124,107,255,.15);
  border: 1px solid rgba(124,107,255,.3);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 11px; font-weight: 700; line-height: 1;
  color: var(--violet-light);
  flex-shrink: 0;
  margin-top: 1px;
  box-sizing: border-box;
}
.step-title {
  font-family: var(--font-display);
  font-size: 17px; font-weight: 700;
  color: #fff; letter-spacing: -.02em;
}
.step-subtitle { font-size: 12px; color: rgba(255,255,255,.3); margin-top: 2px; }

/* ── OPTION GRIDS ──────────────────────── */
.opts { display: grid; gap: 10px; }
.opts-2 { grid-template-columns: 1fr 1fr; }
.opts-3 { grid-template-columns: 1fr 1fr 1fr; }
.opts-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }

.opt { position: relative; cursor: none; }
.opt input { position: absolute; opacity: 0; width: 0; height: 0; }
.opt-label {
  display: flex; flex-direction: column; gap: 5px;
  padding: 16px 18px;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.09);
  border-radius: 12px;
  cursor: none;
  transition: all .2s;
  user-select: none;
  height: 100%;
}
.opt-label:hover {
  border-color: rgba(124,107,255,.3);
  background: rgba(124,107,255,.05);
}
.opt input:checked + .opt-label {
  border-color: var(--violet);
  background: rgba(124,107,255,.12);
  box-shadow: 0 0 0 1px rgba(124,107,255,.25) inset;
}
/* Disabled opt */
.opt.disabled .opt-label {
  opacity: .32;
  cursor: not-allowed;
  pointer-events: none;
}
.opt.disabled .opt-label:hover {
  border-color: rgba(255,255,255,.09);
  background: rgba(255,255,255,.03);
}
.opt-icon { width:28px; height:28px; display:flex; align-items:center; justify-content:center; }
.opt-icon svg { width:22px; height:22px; stroke:rgba(255,255,255,.45); transition:stroke .2s; }
.opt input:checked + .opt-label .opt-icon svg { stroke:var(--violet-light); }
.opt-name {
  font-family: var(--font-display);
  font-size: 14px; font-weight: 600; color: #fff;
}
.opt-desc { font-size: 12px; color: rgba(255,255,255,.36); line-height: 1.5; }
.opt-price { font-size: 11px; font-weight: 600; color: var(--violet-light); margin-top: auto; padding-top: 4px; }
.opt input:checked + .opt-label .opt-price { color: #c4b5fd; }
.opt-badge {
  display: inline-flex;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  background: rgba(236,72,153,.18);
  color: #f9a8d4;
  border: 1px solid rgba(236,72,153,.25);
  border-radius: 100px;
  padding: 2px 7px;
  margin-top: 2px;
  width: fit-content;
}

/* ── SIZE OPTIONS ─────────────────────── */
.size-group { display: none; flex-direction: column; gap: 8px; }
.size-group.visible { display: flex; }

/* Slider labels */
.slider-wrap { padding: 4px 0; }
.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
  gap: 4px;
}
.slider-label {
  font-size: 12px;
  color: rgba(255,255,255,.3);
  text-align: center;
  flex: 1;
  cursor: none;
  line-height: 1.4;
  transition: color .2s;
}
.slider-label.active { color: var(--violet-light); font-weight: 600; }

/* Force sliders to full width */
.slider-wrap input[type=range] {
  width: 100%;
  display: block;
  box-sizing: border-box;
}

/* ── ADDON TOGGLES ─────────────────────── */
.addon {
  display: flex; align-items: center; gap: 14px;
  padding: 13px 16px;
  background: rgba(255,255,255,.025);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 10px;
  cursor: none;
  transition: all .2s;
  user-select: none;
}
.addon:hover { border-color: rgba(124,107,255,.25); background: rgba(124,107,255,.04); }
.addon.checked { border-color: rgba(124,107,255,.4); background: rgba(124,107,255,.08); }
.addon.dimmed {
  opacity: .28;
  pointer-events: none;
  cursor: not-allowed;
}
.addon-cb {
  width: 18px; height: 18px;
  border-radius: 5px;
  border: 1.5px solid rgba(255,255,255,.22);
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all .2s;
}
.addon.checked .addon-cb { background: var(--violet); border-color: var(--violet); }
.addon-check { font-size: 11px; color: #fff; display: none; }
.addon.checked .addon-check { display: block; }
.addon-body { flex: 1; min-width: 0; }
.addon-name { font-size: 13px; font-weight: 600; color: #fff; }
.addon-desc { font-size: 11px; color: rgba(255,255,255,.35); margin-top: 2px; }
.addon-price { font-size: 12px; font-weight: 600; color: var(--violet-light); flex-shrink: 0; }

/* ── FORM ──────────────────────────────── */
.form-field { display: flex; flex-direction: column; gap: 6px; }
.form-label {
  font-size: 11px; color: rgba(255,255,255,.32);
  letter-spacing: .1em; text-transform: uppercase;
}
.form-input {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.09);
  border-radius: 9px;
  padding: 11px 14px;
  color: #fff; font-size: 13px;
  font-family: inherit;
  outline: none;
  transition: border-color .2s;
  width: 100%;
}
.form-input:focus { border-color: rgba(124,107,255,.45); }
textarea.form-input { resize: none; }

/* ── RESULT SIDEBAR ────────────────────── */
.calc-result { position: sticky; top: 100px; }
.result-card {
  background: rgba(124,107,255,.07);
  border: 1px solid rgba(124,107,255,.22);
  border-radius: 18px;
  padding: 26px;
  margin-bottom: 14px;
}
.result-lbl {
  font-size: 10px; letter-spacing: .16em; text-transform: uppercase;
  color: rgba(255,255,255,.28); font-weight: 600; margin-bottom: 8px;
}
.result-price {
  font-family: var(--font-display);
  font-size: 44px; font-weight: 800; letter-spacing: -.05em;
  background: var(--grad-hero);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1; margin-bottom: 4px;
  transition: opacity .25s;
}
.result-divider { height: 1px; background: rgba(255,255,255,.07); margin: 18px 0; }
.result-rows { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.result-row {
  display: flex; justify-content: space-between; align-items: baseline;
  font-size: 13px;
}
.result-row-name { color: rgba(255,255,255,.38); }
.result-row-val { color: rgba(255,255,255,.72); font-weight: 500; font-family: var(--font-display); text-align: right; max-width: 55%; line-height: 1.3; }
.result-note { font-size: 11px; color: rgba(255,255,255,.22); line-height: 1.6; margin-bottom: 18px; text-align: center; }

.info-card {
  background: rgba(255,255,255,.022);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 14px;
  padding: 18px; margin-bottom: 12px;
}
.info-card h4 { font-family:var(--font-display); font-size:13px; font-weight:600; color:rgba(255,255,255,.52); margin-bottom:8px; }
.info-card p { font-size:12px; color:rgba(255,255,255,.3); line-height:1.6; margin:0; }
.trust-list { display: flex; flex-direction: column; gap: 7px; margin-top: 12px; }
.trust-item { display:flex; align-items:center; gap:8px; font-size:12px; color:rgba(255,255,255,.35); }

/* ── RESPONSIVE ────────────────────────── */
@media (max-width: 1100px) {
  .calc-wrap { grid-template-columns: 1fr; gap: 32px; padding: 0 28px 64px; }
  .calc-result { position: static; }
  .opts-4 { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .calc-wrap { padding: 0 16px 48px; }
  .calc-step { padding: 20px; }
  .opts-2, .opts-3, .opts-4 { grid-template-columns: 1fr; }
  .result-price { font-size: 36px; }
}
</style>

<!-- HERO -->
<section class="calc-hero">
  <div class="orb orb-1" style="opacity:.5"></div>
  <div class="orb orb-2" style="opacity:.4"></div>
  <div class="grid-bg"></div>
  <div class="container" style="position:relative">
    <div class="eyebrow" style="justify-content:center;margin-bottom:18px">Transparentna wycena</div>
    <h1 class="display-xl" style="margin-bottom:16px">
      Ile będzie kosztował<br><span class="grad">Twój projekt?</span>
    </h1>
    <p class="calc-hero-sub">
      Skonfiguruj projekt i otrzymaj orientacyjną wycenę w 2 minuty.<br>
      Bez zostawiania danych, bez czekania.
    </p>
  </div>
</section>

<div class="calc-wrap" id="calculator">

  <!-- ════════════════════════════════
       LEFT: STEPS
       ════════════════════════════════ -->
  <div class="calc-steps">

    <!-- ── STEP 1: Project type ── -->
    <div class="calc-step active" id="step-1">
      <div class="step-head">
        <div class="step-num">1</div>
        <div>
          <div class="step-title">Rodzaj projektu</div>
          <div class="step-subtitle">Co chcesz zbudować?</div>
        </div>
      </div>
      <div class="opts opts-4" id="opts-type">
        <label class="opt">
          <input type="radio" name="type" value="landing" checked>
          <div class="opt-label">
            <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
            <div class="opt-name">Landing Page</div>
            <div class="opt-desc">Jedna strona sprzedażowa lub wizytówka. Idealna do kampanii i konwersji.</div>
            <div class="opt-price">od 2 000 zł</div>
          </div>
        </label>
        <label class="opt">
          <input type="radio" name="type" value="firmowa">
          <div class="opt-label">
            <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg></div>
            <div class="opt-name">Strona firmowa</div>
            <div class="opt-desc">Wielopodstronowa witryna WordPress z blogiem, sekcjami i CMS.</div>
            <div class="opt-price">od 4 000 zł</div>
          </div>
        </label>
        <label class="opt">
          <input type="radio" name="type" value="sklep">
          <div class="opt-label">
            <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div>
            <div class="opt-name">Sklep internetowy</div>
            <div class="opt-desc">WooCommerce z pełnym procesem zakupowym, koszyk, płatności, zamówienia.</div>
            <div class="opt-price">od 8 000 zł</div>
          </div>
        </label>
        <label class="opt">
          <input type="radio" name="type" value="custom">
          <div class="opt-label">
            <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
            <div class="opt-name">Custom / Aplikacja</div>
            <div class="opt-desc">Dedykowane rozwiązanie, konfigurator, platforma, integracje API.</div>
            <div class="opt-price">od 12 000 zł</div>
          </div>
        </label>
      </div>
    </div>

    <!-- ── STEP 2: Tech stack ── -->
    <div class="calc-step" id="step-2">
      <div class="step-head">
        <div class="step-num">2</div>
        <div>
          <div class="step-title">Technologia</div>
          <div class="step-subtitle">Na czym chcesz zbudować projekt?</div>
        </div>
      </div>
      <div class="opts opts-2" id="opts-tech">
        <label class="opt" id="opt-wp">
          <input type="radio" name="tech" value="wp" checked>
          <div class="opt-label">
            <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
            <div class="opt-name">WordPress</div>
            <div class="opt-desc">Sprawdzony CMS — łatwy w obsłudze, ekosystem WooCommerce, samodzielne zarządzanie treścią.</div>
            <div class="opt-price">Ceny standardowe</div>
          </div>
        </label>
        <label class="opt" id="opt-next">
          <input type="radio" name="tech" value="next">
          <div class="opt-label">
            <div class="opt-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div>
            <div class="opt-name">Next.js / Astro.js</div>
            <div class="opt-desc">Maksymalna wydajność, wynik Lighthouse 98+, zaawansowane animacje. Tylko dla LP i stron firmowych.</div>
            <div class="opt-price">+60% do wyceny</div>
            <div class="opt-badge">Premium tech</div>
          </div>
        </label>
      </div>
      <p id="tech-note" style="display:none;font-size:12px;color:rgba(252,165,165,.7);margin-top:12px;padding:10px 14px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.18);border-radius:8px">
         Next.js / Astro.js niedostępne dla sklepów i aplikacji custom — automatycznie ustawiono WordPress.
      </p>
    </div>

    <!-- ── STEP 4: Size (conditional) ── -->
    <div class="calc-step" id="step-3">
      <div class="step-head">
        <div class="step-num">3</div>
        <div>
          <div class="step-title" id="size-step-title">Zakres projektu</div>
          <div class="step-subtitle" id="size-step-sub">Ile podstron / jak duży projekt?</div>
        </div>
      </div>

      <!-- LANDING: one-page, no size choice -->
      <div class="size-group visible" id="sg-landing">
        <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:rgba(124,107,255,.06);border:1px solid rgba(124,107,255,.18);border-radius:10px">
          <span style="font-size:20px"></span>
          <div>
            <div style="font-size:14px;font-weight:600;color:#fff;font-family:var(--font-display)">One-page — jedna strona</div>
            <div style="font-size:12px;color:rgba(255,255,255,.38);margin-top:2px">Landing page to zawsze format one-page — jedna długa strona ze wszystkimi sekcjami.</div>
          </div>
        </div>
      </div>

      <!-- FIRMOWA: slider -->
      <div class="size-group" id="sg-firmowa">
        <div class="slider-wrap">
          <div class="slider-labels" id="sl-firmowa-labels">
            <span class="slider-label active" data-idx="0">1–3 podstrony<br><span style="color:rgba(255,255,255,.22);font-size:10px">4 000 zł</span></span>
            <span class="slider-label" data-idx="1">4–8 podstron<br><span style="color:rgba(255,255,255,.22);font-size:10px">5 500 zł</span></span>
            <span class="slider-label" data-idx="2">9–15 podstron<br><span style="color:rgba(255,255,255,.22);font-size:10px">6 800 zł</span></span>
            <span class="slider-label" data-idx="3">Powyżej 15<br><span style="color:rgba(255,255,255,.22);font-size:10px">Wycena indyw.</span></span>
          </div>
          <input type="range" id="slider-firmowa" min="0" max="3" value="0" step="1" style="width:100%">
          <div id="sl-firmowa-desc" style="margin-top:14px;font-size:13px;color:rgba(255,255,255,.38);line-height:1.5;padding:12px 14px;background:rgba(255,255,255,.025);border-radius:9px;border:1px solid rgba(255,255,255,.06)">
            Strona główna + 2 podstrony (np. O nas, Kontakt).
          </div>
        </div>
      </div>

      <!-- SKLEP: slider -->
      <div class="size-group" id="sg-sklep">
        <div style="font-size:12px;color:rgba(167,139,250,.8);background:rgba(124,107,255,.08);border:1px solid rgba(124,107,255,.18);border-radius:8px;padding:10px 14px;margin-bottom:14px">
          ✓ W cenie zawsze: pełny proces zakupowy WooCommerce — koszyk, checkout, płatności (Przelewy24/PayU), strona zamówienia, panel klienta.
        </div>
        <div class="slider-wrap">
          <div class="slider-labels" id="sl-sklep-labels">
            <span class="slider-label active" data-idx="0">1–3 podstrony<br><span style="color:rgba(255,255,255,.22);font-size:10px">8 000 zł</span></span>
            <span class="slider-label" data-idx="1">4–8 podstron<br><span style="color:rgba(255,255,255,.22);font-size:10px">11 000 zł</span></span>
            <span class="slider-label" data-idx="2">9–15 podstron<br><span style="color:rgba(255,255,255,.22);font-size:10px">15 000 zł</span></span>
            <span class="slider-label" data-idx="3">Powyżej 15<br><span style="color:rgba(255,255,255,.22);font-size:10px">Wycena indyw.</span></span>
          </div>
          <input type="range" id="slider-sklep" min="0" max="3" value="0" step="1" style="width:100%">
          <div id="sl-sklep-desc" style="margin-top:14px;font-size:13px;color:rgba(255,255,255,.38);line-height:1.5;padding:12px 14px;background:rgba(255,255,255,.025);border-radius:9px;border:1px solid rgba(255,255,255,.06)">
            Sklep z gotowym motywem, strona główna + do 3 dodatkowych.
          </div>
        </div>
      </div>

      <!-- CUSTOM: fixed -->
      <div class="size-group" id="sg-custom">
        <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:rgba(124,107,255,.06);border:1px solid rgba(124,107,255,.18);border-radius:10px">
          <span style="font-size:20px">⚙️</span>
          <div>
            <div style="font-size:14px;font-weight:600;color:#fff;font-family:var(--font-display)">Zakres ustalany indywidualnie</div>
            <div style="font-size:12px;color:rgba(255,255,255,.38);margin-top:2px">Projekt custom wyceniamy po rozmowie — zakres, czas i cena zależą od wymagań.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── STEP 5: Add-ons ── -->
    <div class="calc-step" id="step-4">
      <div class="step-head">
        <div class="step-num">4</div>
        <div>
          <div class="step-title">Dodatkowe usługi</div>
          <div class="step-subtitle">Opcjonalnie — wybierz co jeszcze potrzebujesz</div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px">
        <div class="addon" id="addon-seo-basic" data-price="1500" data-label="SEO Podstawowe" data-mutex="addon-seo-adv">
          <div class="addon-cb"><span class="addon-check">✓</span></div>
          <div class="addon-body">
            <div class="addon-name">SEO Podstawowe</div>
            <div class="addon-desc">Optymalizacja techniczna, meta tagi, sitemap, schema markup, Google Search Console</div>
          </div>
          <div class="addon-price">+1 500 zł</div>
        </div>
        <div class="addon" id="addon-seo-adv" data-price="3000" data-label="SEO Zaawansowane" data-mutex="addon-seo-basic">
          <div class="addon-cb"><span class="addon-check">✓</span></div>
          <div class="addon-body">
            <div class="addon-name">SEO Zaawansowane</div>
            <div class="addon-desc">Audyt słów kluczowych, optymalizacja treści, linkowanie, 3 miesiące monitoringu</div>
          </div>
          <div class="addon-price">+3 000 zł</div>
        </div>
