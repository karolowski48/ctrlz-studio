---
import Layout from './Layout.astro';
import SharedNav from '../components/SharedNav.astro';
import SharedFooter from '../components/SharedFooter.astro';

interface Props {
  title: string;
  description: string;
  cat: string;
  year: string;
  tags: string[];
  result: string;
  bgClass: string;
  glowClass: string;
  glowColor: string;
  prevSlug?: string;
  prevName?: string;
  nextSlug?: string;
  nextName?: string;
  heroImage?: string;
  heroImageAlt?: string;
}

const { title, description, cat, year, tags, result, bgClass, glowClass, glowColor, prevSlug, prevName, nextSlug, nextName, heroImage, heroImageAlt } = Astro.props;
---

<Layout title={`${title} — Realizacje CtrlZ Studio`} description={description}>

<SharedNav />

<style is:global>
  .proj-hero {
    padding: 140px 0 0;
    position: relative;
    overflow: hidden;
    background: var(--bg-base);
  }
  .proj-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .proj-cat-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .proj-cat-row a { text-decoration:none; }
  .proj-cat-pill {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    background: rgba(124,107,255,.15);
    color: #c4b5fd;
    border: 1px solid rgba(124,107,255,.3);
  }
  .proj-tag { cursor:pointer; }
  a.proj-tag:hover, a.proj-cat-pill:hover { opacity:.8; transform:translateY(-1px); display:inline-block; }
  .proj-tag {
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 100px;
    background: rgba(255,255,255,.05);
    color: rgba(255,255,255,.4);
    border: 1px solid rgba(255,255,255,.09);
  }
  .proj-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px,5vw,64px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -.04em;
    color: #fff;
    margin-bottom: 20px;
  }
  .proj-hero-desc {
    font-size: 17px;
    color: rgba(255,255,255,.45);
    line-height: 1.7;
    max-width: 660px;
    font-weight: 300;
    margin-bottom: 36px;
  }
  .proj-result-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,197,94,.1);
    border: 1px solid rgba(34,197,94,.25);
    border-radius: 100px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(134,239,172,.9);
    margin-bottom: 48px;
  }
  .result-dot { width:7px; height:7px; border-radius:50%; background:#22c55e; box-shadow:0 0 8px #22c55e; }

  /* Mock screen */
  .proj-screen {
    width: 100%;
    height: 400px;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    position: relative;
    margin-top: 8px;
  }
  .proj-screen-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .proj-screen-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }
  .proj-screen-ui {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 32px;
  }
  .pui-bar {
    height: 6px;
    border-radius: 3px;
    background: rgba(255,255,255,.08);
    margin-bottom: 8px;
  }
  .pui-bar:first-child { width: 40%; background: rgba(124,107,255,.55); }
  .pui-bar:nth-child(2) { width: 65%; }
  .pui-bar:nth-child(3) { width: 50%; }
  .pui-cards {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 12px;
    margin-top: 20px;
  }
  .pui-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 8px;
    height: 80px;
  }

  /* Content */
  .proj-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 64px 48px 96px;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
    align-items: start;
    background: var(--bg-base);
  }
  .proj-content { min-width: 0; }
  .proj-content h2 {
    font-family: var(--font-display);
    font-size: clamp(20px,2.2vw,26px);
    font-weight: 700;
    color: #fff;
    letter-spacing: -.025em;
    margin: 52px 0 16px;
    padding-left: 18px;
    border-left: 3px solid var(--violet);
    line-height: 1.25;
  }
  .proj-content h2:first-of-type { margin-top: 0; }
  .proj-content h2:first-child { margin-top: 0; border-top: none; }
  .proj-content h3 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: rgba(255,255,255,.88);
    margin: 32px 0 12px;
  }
  .proj-content p {
    font-size: 16px;
    color: rgba(255,255,255,.55);
    line-height: 1.85;
    margin-bottom: 20px;
  }
  .proj-content p strong { color: rgba(255,255,255,.85); font-weight: 600; }
  .proj-content ul {
    padding-left: 0;
    margin-bottom: 24px;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .proj-content li {
    font-size: 16px;
    color: rgba(255,255,255,.55);
    line-height: 1.78;
    padding-left: 20px;
    position: relative;
  }
  .proj-content ul li::before {
    content: '';
    position: absolute;
    left: 0; top: 9px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--violet-light);
    opacity: .65;
  }
  .proj-content li strong { color: rgba(255,255,255,.82); }
  .proj-highlight {
    background: rgba(124,107,255,.07);
    border: 1px solid rgba(124,107,255,.2);
    border-radius: 14px;
    padding: 24px 28px;
    margin: 32px 0;
  }
  .proj-highlight h4 {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--violet-light);
    margin: 0 0 8px;
  }
  .proj-highlight p { font-size: 14px; color: rgba(255,255,255,.45); margin: 0; }
  .proj-results-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 16px;
    margin: 32px 0;
  }
  .proj-result-card {
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all var(--transition);
  }
  .proj-result-card:hover { border-color: rgba(124,107,255,.25); background: rgba(124,107,255,.05); }
  .prc-num {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -.04em;
    background: var(--grad-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .prc-label { font-size: 12px; color: rgba(255,255,255,.35); margin-top: 6px; line-height: 1.4; }

  /* Sidebar */
  .proj-sidebar {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .proj-sidebar::-webkit-scrollbar { display: none; }
  .proj-info-card {
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 14px;
    padding: 22px;
    margin-bottom: 16px;
  }
  .proj-info-card h4 {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,.28);
    letter-spacing: .14em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }
  .proj-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,.05);
    font-size: 13px;
  }
  .proj-info-row:last-child { border-bottom: none; }
  .proj-info-label { color: rgba(255,255,255,.3); flex-shrink: 0; padding-top: 1px; }
  .proj-info-val { color: rgba(255,255,255,.75); font-weight: 500; text-align: right; line-height: 1.4; }
  .proj-tech-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .proj-tech-tag {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(124,107,255,.1);
    color: #c4b5fd;
    border: 1px solid rgba(124,107,255,.18);
  }

  /* Navigation between projects */
  .proj-nav {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 48px 64px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid rgba(255,255,255,.05);
  }
  .proj-nav-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px 22px;
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 12px;
    flex: 1;
    max-width: 280px;
    transition: all var(--transition);
    cursor: none;
  }
  .proj-nav-link:hover { border-color: rgba(124,107,255,.28); background: rgba(124,107,255,.05); }
  .proj-nav-link.next { align-items: flex-end; text-align: right; }
  .proj-nav-dir { font-size: 10px; color: rgba(255,255,255,.22); letter-spacing: .1em; text-transform: uppercase; }
  .proj-nav-title { font-family: var(--font-display); font-size: 14px; font-weight: 600; color: rgba(255,255,255,.75); }
  .back-link { display:inline-flex; align-items:center; gap:8px; font-size:13px; color:rgba(255,255,255,.35); margin-bottom:40px; transition:color .2s; }
  .back-link:hover { color:rgba(255,255,255,.7); }

  /* CTA */
  .proj-cta-box {
    background: linear-gradient(135deg,rgba(124,107,255,.12),rgba(236,72,153,.06));
    border: 1px solid rgba(124,107,255,.25);
    border-radius: 18px;
    padding: 40px;
    text-align: center;
    margin-top: 56px;
  }
  .proj-cta-box h3 { font-family:var(--font-display); font-size:24px; color:#fff; margin:0 0 10px; }
  .proj-cta-box p  { font-size:15px; color:rgba(255,255,255,.45); margin-bottom:24px; }

  @media (max-width:1024px) {
    .proj-wrap { grid-template-columns:1fr; gap:40px; padding:40px 28px 64px; }
    .proj-sidebar { position:static; }
    .proj-hero-inner { padding:0 28px; }
    .proj-results-grid { grid-template-columns:1fr 1fr; }
    .proj-nav { padding:24px 28px 48px; }
  }
  @media (max-width:640px) {
    .proj-wrap { padding:28px 16px 48px; }
    .proj-hero-inner { padding:0 16px; }
    .proj-screen { height:240px; }
    .proj-results-grid { grid-template-columns:1fr; }
    .proj-nav { flex-direction:column; }
    .proj-nav-link.next { align-items:flex-start; text-align:left; max-width:100%; }
    .proj-nav-link { max-width:100%; }
    .pui-cards { grid-template-columns:1fr 1fr; }
  }
</style>

<main id="main-content">
<section class="proj-hero">
  <div class="orb" style={`width:600px;height:600px;background:radial-gradient(circle,${glowColor} 0%,transparent 65%);top:-250px;right:-100px;filter:blur(60px)`}></div>
  <div class="grid-bg"></div>
  <div class="proj-hero-inner">
    <a href="/realizacje" class="back-link" style="display:inline-flex;align-items:center;gap:8px;font-size:13px;color:rgba(255,255,255,.32);margin-bottom:24px;transition:color .2s">← Wróć do realizacji</a>
    <div class="proj-cat-row">
      <a href={`/realizacje?cat=${encodeURIComponent(cat)}`} class="proj-cat-pill">{cat}</a>
      {tags.map(t => <a href={`/realizacje?cat=${encodeURIComponent(t)}`} class="proj-tag">{t}</a>)}
      <span class="proj-tag">{year}</span>
    </div>
    <h1>{title}</h1>
    <p class="proj-hero-desc">{description}</p>
    <div class="proj-result-badge"><div class="result-dot"></div>{result}</div>
  </div>

  <!-- Project hero: photo or mock -->
  <div style="max-width:1280px;margin:0 auto;padding:0 48px">
    {heroImage ? (
      <div class={`proj-screen ${bgClass}`} style="overflow:hidden;padding:0">
        <img
          src={heroImage}
          alt={heroImageAlt || title}
          style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;opacity:.85"
          loading="eager"
        />
      </div>
    ) : (
      <div class={`proj-screen ${bgClass}`}>
        <div class="proj-screen-bg">
          <div class={`proj-screen-glow ${glowClass}`} style="width:300px;height:300px;top:10%;right:10%"></div>
        </div>
        <div class="proj-screen-ui">
          <div class="pui-bar"></div>
          <div class="pui-bar"></div>
          <div class="pui-bar"></div>
          <div class="pui-cards">
            <div class="pui-card"></div>
            <div class="pui-card"></div>
            <div class="pui-card"></div>
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<div class="proj-wrap">
  <div class="proj-content">
    <slot />
    <div class="proj-cta-box">
      <h3>Chcesz podobne efekty?</h3>
      <p>Opowiedz nam o swoim projekcie. Pierwsza konsultacja jest bezpłatna.</p>
      <a href="/#kontakt" class="btn-primary"><span>Zacznijmy rozmowę →</span></a>
    </div>
  </div>

  <aside class="proj-sidebar">
    <div class="proj-info-card">
      <h3>Szczegóły projektu</h3>
      <div class="proj-info-row"><span class="proj-info-label">Kategoria</span><span class="proj-info-val">{cat}</span></div>
      <div class="proj-info-row"><span class="proj-info-label">Rok</span><span class="proj-info-val">{year}</span></div>
      <div class="proj-info-row"><span class="proj-info-label">Wynik</span><span class="proj-info-val" style="color:rgba(134,239,172,.9)">{result}</span></div>
    </div>

    <div class="proj-info-card">
      <h3>Technologie</h3>
      <div class="proj-tech-list">
        {tags.map(t => <span class="proj-tech-tag">{t}</span>)}
      </div>
    </div>

    <div class="proj-info-card">
      <h3>Inne realizacje</h3>
      <a href="/realizacje/modeka" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(234,88,12,.8);flex-shrink:0"></div>Modeka — B2B e-commerce
      </a>
      <a href="/realizacje/eduinspirations" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(167,139,250,.8);flex-shrink:0"></div>EduInspirations.pl
      </a>
      <a href="/realizacje/techopiekun" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(74,222,128,.8);flex-shrink:0"></div>TechOpiekun.pl
      </a>
      <a href="/realizacje/ayra-jubiler" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(212,175,55,.8);flex-shrink:0"></div>Ayra Jubiler
      </a>
      <a href="/realizacje/ksiegowosc-online-365" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(59,130,246,.8);flex-shrink:0"></div>Księgowość Online 365
      </a>
      <a href="/realizacje/old-gold-garage" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(234,179,8,.8);flex-shrink:0"></div>Old Gold Garage
      </a>
      <a href="/realizacje/jakub-kasprowicz" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(139,92,246,.8);flex-shrink:0"></div>Jakub Kasprowicz
      </a>
      <a href="/realizacje/konieczny-konstrukcje" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(180,120,40,.8);flex-shrink:0"></div>Konieczny Konstrukcje
      </a>
      <a href="/realizacje/beskid-stolarstwo" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(34,160,80,.8);flex-shrink:0"></div>Beskid Stolarstwo
      </a>
      <a href="/realizacje/gabriela-piwowarska" style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(236,72,153,.8);flex-shrink:0"></div>Gabriela Piwowarska
      </a>
      <a href="/realizacje/dziki-gym" style="display:flex;align-items:center;gap:10px;padding:8px 0;text-decoration:none;transition:color .2s;color:rgba(255,255,255,.42);font-size:13px">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(220,38,38,.8);flex-shrink:0"></div>Dziki Gym
      </a>
    </div>

    <a href="/#kontakt" class="btn-primary" style="width:100%;justify-content:center;border-radius:12px">
      <span>Wycena projektu →</span>
    </a>
  </aside>
</div>

<!-- Next/Prev navigation -->
<div class="proj-nav">
  {prevSlug && prevName && (
    <a href={`/realizacje/${prevSlug}`} class="proj-nav-link">
      <span class="proj-nav-dir">← Poprzedni projekt</span>
      <span class="proj-nav-title">{prevName}</span>
    </a>
  )}
  {nextSlug && nextName && (
    <a href={`/realizacje/${nextSlug}`} class="proj-nav-link next">
      <span class="proj-nav-dir">Następny projekt →</span>
      <span class="proj-nav-title">{nextName}</span>
    </a>
  )}
</div>

</main>

<SharedFooter />

</Layout>

<script>
import { initPage } from '../utils/pageInit';
import gsap from 'gsap';
initPage();
gsap.fromTo('.proj-hero h1',    {opacity:0,y:28},{opacity:1,y:0,duration:.9,ease:'power3.out',delay:.25});
gsap.fromTo('.proj-hero-desc',  {opacity:0,y:18},{opacity:1,y:0,duration:.7,ease:'power3.out',delay:.4});
gsap.fromTo('.proj-result-badge',{opacity:0,y:12},{opacity:1,y:0,duration:.6,ease:'power3.out',delay:.55});
gsap.fromTo('.proj-screen',     {opacity:0,y:32},{opacity:1,y:0,duration:1,  ease:'power3.out',delay:.45});
gsap.fromTo('.proj-content',    {opacity:0,y:24},{opacity:1,y:0,duration:.8,ease:'power3.out',delay:.3});
gsap.fromTo('.proj-sidebar',    {opacity:0,x:20},{opacity:1,x:0,duration:.8,ease:'power3.out',delay:.5});
</script>
